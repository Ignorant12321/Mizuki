---
import { clickEffectConfig } from "@/config";

const blacklist = clickEffectConfig.blacklist || [];
const desktopEnabled = clickEffectConfig.enable !== false;
const mobileEnabled = clickEffectConfig.mobile ?? false;
---

<template
	id="click-effect-config"
	data-blacklist={JSON.stringify(blacklist)}
	data-enable-desktop={desktopEnabled ? "true" : "false"}
	data-enable-mobile={mobileEnabled ? "true" : "false"}></template>

<style>
	:global(.click-particle) {
		position: fixed;
		pointer-events: none;
		width: 14px;
		height: 14px;
		border-radius: 50%;
		z-index: 9999;
		will-change: transform, opacity;
		animation: particle-explosion 0.48s cubic-bezier(0.18, 0.84, 0.32, 1) both;
		box-shadow: 0 0 4px rgba(255, 255, 255, 0.72);
	}

	:global(.dark .click-particle) {
		box-shadow: 0 0 8px rgba(255, 255, 255, 0.4);
	}

	@keyframes particle-explosion {
		0% {
			opacity: 1;
			transform: scale(0.4) translate(0, 0);
		}
		18% {
			opacity: 1;
			transform: scale(1.12) translate(var(--dx), var(--dy));
		}
		45% {
			opacity: 0.45;
			transform: scale(1)
				translate(calc(var(--dx) * 2.2), calc(var(--dy) * 2.2));
		}
		100% {
			opacity: 0;
			transform: scale(0.1)
				translate(calc(var(--dx) * 2.8), calc(var(--dy) * 2.8));
		}
	}

	:global(.click-particle.color-1) {
		background: radial-gradient(circle, #ffb3ba 0%, #ffc1cc 100%);
	}
	:global(.click-particle.color-2) {
		background: radial-gradient(circle, #a8d8ff 0%, #bde4ff 100%);
	}
	:global(.click-particle.color-3) {
		background: radial-gradient(circle, #ffe66d 0%, #fff2a8 100%);
	}
	:global(.click-particle.color-4) {
		background: radial-gradient(circle, #d4a5ff 0%, #e6ccff 100%);
	}
	:global(.click-particle.color-5) {
		background: radial-gradient(circle, #a8e6a8 0%, #c1ffc1 100%);
	}
	:global(.click-particle.color-6) {
		background: radial-gradient(circle, #ffcc99 0%, #ffd4a3 100%);
	}
	:global(.click-particle.color-7) {
		background: radial-gradient(circle, #b3deff 0%, #c4e8ff 100%);
	}
	:global(.click-particle.color-8) {
		background: radial-gradient(circle, #f5c2c7 0%, #f8d7da 100%);
	}
	:global(.click-particle.color-9) {
		background: radial-gradient(circle, #c3e6c3 0%, #d1f2d1 100%);
	}
	:global(.click-particle.color-10) {
		background: radial-gradient(circle, #ffe8b3 0%, #fff0d4 100%);
	}

	:global(.dark .click-particle.color-1) {
		background: radial-gradient(circle, #ff4757 0%, #ff6b8a 100%);
	}
	:global(.dark .click-particle.color-2) {
		background: radial-gradient(circle, #29b6f6 0%, #4fc3f7 100%);
	}
	:global(.dark .click-particle.color-3) {
		background: radial-gradient(circle, #ffca28 0%, #ffd54f 100%);
	}
	:global(.dark .click-particle.color-4) {
		background: radial-gradient(circle, #ab47bc 0%, #ba68c8 100%);
	}
	:global(.dark .click-particle.color-5) {
		background: radial-gradient(circle, #66bb6a 0%, #81c784 100%);
	}
	:global(.dark .click-particle.color-6) {
		background: radial-gradient(circle, #ffa726 0%, #ffb74d 100%);
	}
	:global(.dark .click-particle.color-7) {
		background: radial-gradient(circle, #42a5f5 0%, #64b5f6 100%);
	}
	:global(.dark .click-particle.color-8) {
		background: radial-gradient(circle, #f06292 0%, #f48fb1 100%);
	}
	:global(.dark .click-particle.color-9) {
		background: radial-gradient(circle, #81c784 0%, #a5d6a7 100%);
	}
	:global(.dark .click-particle.color-10) {
		background: radial-gradient(circle, #ffd54f 0%, #ffe082 100%);
	}
</style>

<script>
	const CLICK_EFFECT_BOUND_KEY = "__mizukiClickEffectBound";
	// 同时存在的最大粒子数，避免连续点击导致卡顿
	const MAX_ACTIVE_PARTICLES = 84;
	// 原版视觉参数：环形粒子 + 随机粒子
	const RING_PARTICLES = 8;
	const EXTRA_PARTICLES = 2;
	const BASE_DISTANCE = 18;
	const PARTICLE_COLORS = 10;
	const STAGGER_MS = 3;

	let activeParticles = 0;

	function createParticleElement(
		x: number,
		y: number,
		angle: number,
		distance: number,
		colorIndex: number,
		delayMs: number,
	) {
		const particle = document.createElement("div");
		particle.className = `click-particle color-${colorIndex}`;

		const dx = Math.cos(angle) * distance;
		const dy = Math.sin(angle) * distance;
		particle.style.setProperty("--dx", `${dx}px`);
		particle.style.setProperty("--dy", `${dy}px`);
		particle.style.left = `${x}px`;
		particle.style.top = `${y}px`;
		particle.style.animationDelay = `${delayMs}ms`;

		const size = Math.random() * 6 + 8;
		particle.style.width = `${size}px`;
		particle.style.height = `${size}px`;

		activeParticles += 1;
		particle.addEventListener(
			"animationend",
			() => {
				particle.remove();
				activeParticles = Math.max(0, activeParticles - 1);
			},
			{ once: true },
		);

		return particle;
	}

	const configEl = document.getElementById("click-effect-config");
	let blacklist: string[] = [];
	let desktopEnabled = true;
	let mobileEnabled = false;

	if (configEl?.dataset.blacklist) {
		try {
			blacklist = JSON.parse(configEl.dataset.blacklist);
		} catch (e) {
			console.error("Failed to parse click effect blacklist", e);
		}
	}
	if (configEl) {
		desktopEnabled = configEl.dataset.enableDesktop === "true";
		mobileEnabled = configEl.dataset.enableMobile === "true";
	}

	const isMobile =
		(window.matchMedia &&
			(window.matchMedia("(pointer:coarse)").matches ||
				window.matchMedia("(hover: none)").matches ||
				window.matchMedia("(max-width: 768px)").matches)) ||
		"ontouchstart" in window;
	let runtimeEnabled = (() => {
		const stored = localStorage.getItem("clickEffectEnabled");
		if (stored === null) {
			return isMobile ? mobileEnabled : desktopEnabled;
		}
		return stored === "true";
	})();

	const isEffectEnabled = () => {
		return runtimeEnabled;
	};

	if (!(window as any)[CLICK_EFFECT_BOUND_KEY]) {
		const handler = (e: MouseEvent) => {
			if (!isEffectEnabled()) return;

			if (blacklist.length > 0) {
				const target = e.target as HTMLElement | null;
				if (
					target &&
					blacklist.some((selector) => target.closest(selector))
				) {
					return;
				}
			}

			const availableSlots = MAX_ACTIVE_PARTICLES - activeParticles;
			if (availableSlots <= 0) return;

			const toCreate = Math.min(
				RING_PARTICLES + EXTRA_PARTICLES,
				availableSlots,
			);
			const fragment = document.createDocumentFragment();
			let created = 0;

			for (let i = 0; i < RING_PARTICLES && created < toCreate; i++) {
				const angle = ((Math.PI * 2) / RING_PARTICLES) * i;
				const distance = BASE_DISTANCE + Math.random() * 8;
				const colorIndex = (i % PARTICLE_COLORS) + 1;
				fragment.appendChild(
					createParticleElement(
						e.clientX,
						e.clientY,
						angle,
						distance,
						colorIndex,
						i * STAGGER_MS,
					),
				);
				created += 1;
			}

			for (let i = 0; i < EXTRA_PARTICLES && created < toCreate; i++) {
				const randomAngle = Math.random() * Math.PI * 2;
				const randomDistance = BASE_DISTANCE + Math.random() * 10;
				const colorIndex =
					Math.floor(Math.random() * PARTICLE_COLORS) + 1;
				fragment.appendChild(
					createParticleElement(
						e.clientX,
						e.clientY,
						randomAngle,
						randomDistance,
						colorIndex,
						(RING_PARTICLES + i) * STAGGER_MS,
					),
				);
				created += 1;
			}

			document.body.appendChild(fragment);
		};

		const settingChangeHandler = (event: Event) => {
			const customEvent = event as CustomEvent<{
				key?: string;
				value?: unknown;
			}>;
			if (customEvent.detail?.key !== "clickEffectEnabled") return;
			runtimeEnabled = Boolean(customEvent.detail.value);
		};

		document.addEventListener("click", handler, { passive: true });
		window.addEventListener("mizuki:setting-change", settingChangeHandler);
		(window as any)[CLICK_EFFECT_BOUND_KEY] = true;
	}
</script>
