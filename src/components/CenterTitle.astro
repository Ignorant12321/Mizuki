---
interface Props {
	title: string;
	subtitle: string;
	watermark?: string | boolean; // 可传 false 隐藏，或传字符串自定义
	bgImage?: string; // 可选背景图
	desc?: string; // 可选底部说明文字
	divider?: boolean; // 【新增】是否在底部显示虚线分隔
}

const {
	title,
	subtitle,
	watermark = true,
	bgImage,
	desc,
	divider = false,
} = Astro.props;

// 处理水印逻辑：如果为 false 则隐藏；如果传入字符串则使用该字符串；否则默认使用 subtitle
const showWatermark = watermark !== false;
const watermarkText = typeof watermark === "string" ? watermark : subtitle;
---

<div
	class:list={[
		"centerTitle relative w-full overflow-hidden flex flex-col items-center justify-center rounded-2xl",
		bgImage ? "pt-16 pb-12 mb-6" : "pt-6 pb-4 mb-6",
	]}
>
	{
		bgImage && (
			<div class="absolute inset-0 z-0 select-none pointer-events-none bg-(--card-bg)">
				<img
					src={bgImage}
					alt=""
					class="w-full h-full object-cover object-center transition-opacity duration-700 opacity-0"
					onload="this.classList.remove('opacity-0'); this.classList.add('opacity-60');"
				/>
				<div class="absolute inset-0 bg-(--card-bg)/40" />
				<div class="absolute inset-0 bg-gradient-to-t from-(--card-bg) via-(--card-bg)/20 to-transparent" />
			</div>
		)
	}

	{
		showWatermark && (
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[4rem] md:text-[6.5rem] font-black text-black/3 dark:text-white/3 uppercase tracking-[0.2em] select-none pointer-events-none z-0 whitespace-nowrap">
				{watermarkText}
			</div>
		)
	}

	<div class="flex flex-col items-center justify-center w-full relative z-10">
		<slot name="icon">
			<svg
				class="w-6 h-6 md:w-8 md:h-8 text-(--primary) opacity-60 mb-2 drop-shadow-sm"
				viewBox="0 0 24 24"
				fill="none"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path
					d="M12 2C12 7.52285 16.4772 12 22 12C16.4772 12 12 16.4772 12 22C12 16.4772 7.52285 12 2 12C7.52285 12 12 7.52285 12 2Z"
					fill="currentColor"
					opacity="0.3"></path>
				<path
					d="M12 4C12 8.41828 15.5817 12 20 12C15.5817 12 12 15.5817 12 20C12 15.5817 8.41828 12 4 12C8.41828 12 12 8.41828 12 4Z"
					fill="currentColor"></path>
				<circle cx="12" cy="12" r="1.5" fill="var(--card-bg, #ffffff)"
				></circle>
			</svg>
		</slot>

		<div class="flex items-center justify-center w-full group">
			<div
				class="flex-1 flex items-center justify-end opacity-50 group-hover:opacity-80 transition-opacity duration-500 max-w-[120px] md:max-w-[200px]"
			>
				<svg
					class="w-full h-3 text-(--primary)"
					viewBox="0 0 150 12"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					preserveAspectRatio="xMaxYCenter meet"
				>
					<defs>
						<linearGradient
							id="gradLeft"
							x1="150"
							y1="6"
							x2="0"
							y2="6"
							gradientUnits="userSpaceOnUse"
						>
							<stop
								offset="0%"
								stop-color="currentColor"
								stop-opacity="0.7"></stop>
							<stop
								offset="100%"
								stop-color="currentColor"
								stop-opacity="0"></stop>
						</linearGradient>
					</defs>
					<line
						x1="0"
						y1="6"
						x2="128"
						y2="6"
						stroke="url(#gradLeft)"
						stroke-width="1.5"
						stroke-linecap="round"></line>
					<path
						d="M135 4L136.5 6L135 8L133.5 6L135 4Z"
						fill="currentColor"
						opacity="0.8"></path>
					<circle cx="145" cy="6" r="2.5" fill="currentColor"
					></circle>
					<circle
						cx="145"
						cy="6"
						r="4.5"
						stroke="currentColor"
						stroke-width="0.5"
						opacity="0.5"></circle>
				</svg>
			</div>

			<div
				class="flex flex-col items-center px-3 md:px-6 relative cursor-default shrink-0"
			>
				<h2
					class="text-xl md:text-3xl font-bold tracking-widest text-(--primary) drop-shadow-sm whitespace-nowrap m-0"
				>
					{title}
				</h2>
				<span
					class="text-[9px] md:text-[11px] font-mono tracking-[0.2em] md:tracking-[0.3em] opacity-60 mt-1 uppercase text-90 whitespace-nowrap"
				>
					{subtitle}
				</span>
			</div>

			<div
				class="flex-1 flex items-center justify-start opacity-50 group-hover:opacity-80 transition-opacity duration-500 max-w-[120px] md:max-w-[200px]"
			>
				<svg
					class="w-full h-3 text-(--primary)"
					viewBox="0 0 150 12"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					preserveAspectRatio="xMinYCenter meet"
				>
					<defs>
						<linearGradient
							id="gradRight"
							x1="0"
							y1="6"
							x2="150"
							y2="6"
							gradientUnits="userSpaceOnUse"
						>
							<stop
								offset="0%"
								stop-color="currentColor"
								stop-opacity="0.7"></stop>
							<stop
								offset="100%"
								stop-color="currentColor"
								stop-opacity="0"></stop>
						</linearGradient>
					</defs>
					<circle cx="5" cy="6" r="2.5" fill="currentColor"></circle>
					<circle
						cx="5"
						cy="6"
						r="4.5"
						stroke="currentColor"
						stroke-width="0.5"
						opacity="0.5"></circle>
					<path
						d="M15 4L16.5 6L15 8L13.5 6L15 4Z"
						fill="currentColor"
						opacity="0.8"></path>
					<line
						x1="22"
						y1="6"
						x2="150"
						y2="6"
						stroke="url(#gradRight)"
						stroke-width="1.5"
						stroke-linecap="round"></line>
				</svg>
			</div>
		</div>

		{
			desc && (
				<p class="text-xs md:text-sm text-50 mt-4 md:mt-5 opacity-70 font-light tracking-wider text-center px-4 m-0 drop-shadow-sm">
					{desc}
				</p>
			)
		}

		<slot name="bottom" />
	</div>
</div>

{
	divider && (
		<div class="w-full flex justify-center mb-8 relative z-10">
			<div class="w-[80%] md:w-[90%] border-b-2 border-dashed border-(--primary) opacity-70" />
		</div>
	)
}
