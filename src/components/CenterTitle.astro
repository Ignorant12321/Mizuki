---
interface Props {
	title: string;
	subtitle: string;
	watermark?: string | boolean; // 可传 false 隐藏，或传字符串自定义
	bgImage?: string; // 可选背景图
	desc?: string; // 可选底部说明文字
	divider?: boolean; // 【新增】是否在底部显示虚线分隔
}

const {
	title,
	subtitle,
	watermark = true,
	bgImage,
	desc,
	divider = false,
} = Astro.props;

// 处理水印逻辑：如果为 false 则隐藏；如果传入字符串则使用该字符串；否则默认使用 subtitle
const showWatermark = watermark !== false;
const watermarkText = typeof watermark === "string" ? watermark : subtitle;
---

<div
	class:list={[
		"relative w-full overflow-hidden flex flex-col items-center justify-center rounded-2xl",
		bgImage ? "pt-16 pb-12 mb-6" : "pt-6 pb-4 mb-6",
	]}
>
	{
		bgImage && (
			<div class="absolute inset-0 z-0 select-none pointer-events-none bg-(--card-bg)">
				<img
					src={bgImage}
					alt=""
					class="w-full h-full object-cover object-center transition-opacity duration-700 opacity-0"
					onload="this.classList.remove('opacity-0'); this.classList.add('opacity-60');"
				/>
				<div class="absolute inset-0 bg-(--card-bg)/40" />
				<div class="absolute inset-0 bg-gradient-to-t from-(--card-bg) via-(--card-bg)/20 to-transparent" />
			</div>
		)
	}

	{
		showWatermark && (
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[4rem] md:text-[6.5rem] font-black text-black/3 dark:text-white/3 uppercase tracking-[0.2em] select-none pointer-events-none z-0 whitespace-nowrap">
				{watermarkText}
			</div>
		)
	}

	<div class="flex flex-col items-center justify-center w-full relative z-10">
		<slot name="icon">
			<svg
				class="w-4 h-4 md:w-5 md:h-5 text-(--primary) opacity-40 mb-3"
				viewBox="0 0 24 24"
				fill="currentColor"
			>
				<path
					d="M12 2L12.7 9.3L20 10L12.7 10.7L12 18L11.3 10.7L4 10L11.3 9.3L12 2Z"
				></path>
			</svg>
		</slot>

		<div class="flex items-center justify-center w-full group">
			<div
				class="flex-1 flex items-center justify-end opacity-50 group-hover:opacity-80 transition-opacity duration-500 max-w-[120px] md:max-w-[200px]"
			>
				<div
					class="h-px w-full bg-linear-to-l from-(--primary) to-transparent"
				>
				</div>
				<div
					class="w-1 h-1 rounded-full bg-(--primary) ml-2 md:ml-3 shadow-[0_0_8px_var(--primary)] shrink-0"
				>
				</div>
			</div>

			<div
				class="flex flex-col items-center px-3 md:px-6 relative cursor-default shrink-0"
			>
				<h2
					class="text-xl md:text-3xl font-bold tracking-widest text-(--primary) drop-shadow-sm whitespace-nowrap m-0"
				>
					{title}
				</h2>
				<span
					class="text-[9px] md:text-[11px] font-mono tracking-[0.2em] md:tracking-[0.3em] opacity-60 mt-1 uppercase text-90 whitespace-nowrap"
				>
					{subtitle}
				</span>
			</div>

			<div
				class="flex-1 flex items-center justify-start opacity-50 group-hover:opacity-80 transition-opacity duration-500 max-w-[120px] md:max-w-[200px]"
			>
				<div
					class="w-1 h-1 rounded-full bg-(--primary) mr-2 md:mr-3 shadow-[0_0_8px_var(--primary)] shrink-0"
				>
				</div>
				<div
					class="h-px w-full bg-linear-to-r from-(--primary) to-transparent"
				>
				</div>
			</div>
		</div>

		{
			desc && (
				<p class="text-xs md:text-sm text-50 mt-4 md:mt-5 opacity-70 font-light tracking-wider text-center px-4 m-0 drop-shadow-sm">
					{desc}
				</p>
			)
		}

		<slot name="bottom" />
	</div>
</div>

{
	divider && (
		<div class="w-full flex justify-center mb-8 relative z-10">
			<div class="w-[80%] md:w-[90%] border-b-2 border-dashed border-(--primary) opacity-70" />
		</div>
	)
}
