---
export interface Props {
	children: any;
	orientation?: "horizontal" | "vertical";
	tone?: "default" | "slim";
	class?: string;
}

const {
	children,
	orientation = "horizontal",
	tone = "default",
	class: customClass = "",
} = Astro.props;
---

<div
	class={`custom-scrollbar ${orientation === "horizontal" ? "scrollbar-horizontal" : "scrollbar-vertical"} ${customClass}`}
	data-orientation={orientation}
	data-scrollbar-tone={tone === "slim" ? "slim" : undefined}
>
	{children}
</div>
