---
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
const tocDepth = siteConfig.toc.depth;
const useJapaneseBadge = siteConfig.toc.useJapaneseBadge;
const tocLabel = i18n(I18nKey.tableOfContents);
const tocBackToTopLabel = i18n(I18nKey.tocBackToTop);
const floatingTOCPosition = siteConfig.floatingWidgets?.floatingTOC ?? {
	desktop: { side: "left", offset: "-4rem", bottom: "10rem" },
	mobile: { side: "left", offset: "1rem", bottom: "10rem" },
};
const floatingTOCStyle = `--floating-toc-left-desktop:${floatingTOCPosition.desktop.side === "left" ? floatingTOCPosition.desktop.offset : "auto"};--floating-toc-right-desktop:${floatingTOCPosition.desktop.side === "right" ? floatingTOCPosition.desktop.offset : "auto"};--floating-toc-bottom-desktop:${floatingTOCPosition.desktop.bottom};--floating-toc-shift-desktop:${floatingTOCPosition.desktop.side === "left" ? "5rem" : "-5rem"};--floating-toc-panel-left-desktop:${floatingTOCPosition.desktop.side === "left" ? "0" : "auto"};--floating-toc-panel-right-desktop:${floatingTOCPosition.desktop.side === "right" ? "0" : "auto"};--floating-toc-left-mobile:${floatingTOCPosition.mobile.side === "left" ? floatingTOCPosition.mobile.offset : "auto"};--floating-toc-right-mobile:${floatingTOCPosition.mobile.side === "right" ? floatingTOCPosition.mobile.offset : "auto"};--floating-toc-bottom-mobile:${floatingTOCPosition.mobile.bottom};--floating-toc-panel-left-mobile:${floatingTOCPosition.mobile.side === "left" ? "0" : "auto"};--floating-toc-panel-right-mobile:${floatingTOCPosition.mobile.side === "right" ? "0" : "auto"};`;
---

<div
	class="floating-toc-wrapper"
	data-depth={tocDepth}
	data-japanese-badge={useJapaneseBadge}
	style={floatingTOCStyle}
>
	<button
		id="floating-toc-btn"
		class="floating-toc-btn btn-card"
		aria-label={tocLabel}
		title={tocLabel}
	>
		<svg
			class="progress-ring"
			width="100%"
			height="100%"
			viewBox="0 0 100 100"
		>
			<circle
				class="progress-ring-circle"
				cx="50"
				cy="50"
				r="40"
				fill="transparent"></circle>
		</svg>
		<div class="btn-icon">
			<Icon
				name="material-symbols:format-list-bulleted-rounded"
				class="text-2xl"
			/>
		</div>
	</button>
	<div id="floating-toc-panel" class="floating-toc-panel">
		<button
			id="floating-toc-title"
			type="button"
			class="floating-toc-panel-title"
			aria-label={tocBackToTopLabel}
			title={tocBackToTopLabel}
		>
			<span class="floating-toc-panel-title-dot"></span>
			<span>{tocLabel}</span>
		</button>
		<div class="floating-toc-panel-content" id="floating-toc-content"></div>
	</div>
</div>

<style>
	.floating-toc-wrapper {
		--floating-toc-left: var(--floating-toc-left-desktop);
		--floating-toc-right: var(--floating-toc-right-desktop);
		--floating-toc-bottom: var(--floating-toc-bottom-desktop);
		--floating-toc-shift: var(--floating-toc-shift-desktop);
		--floating-toc-panel-left: var(--floating-toc-panel-left-desktop);
		--floating-toc-panel-right: var(--floating-toc-panel-right-desktop);
		position: fixed;
		left: var(--floating-toc-left);
		right: var(--floating-toc-right);
		bottom: var(--floating-toc-bottom);
		z-index: 45;
		pointer-events: auto;
		transform: translateX(var(--floating-toc-shift));
		/* display: none; */
		transition:
			opacity 0.28s ease,
			transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.floating-toc-wrapper.active-toc {
		display: block;
	}

	.floating-toc-btn {
		width: 3.75rem;
		height: 3.75rem;
		border-radius: 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--primary);
		position: relative;
		background: linear-gradient(
			160deg,
			color-mix(in oklab, var(--primary) 12%, var(--card-bg)) 0%,
			var(--card-bg) 80%
		);
		transition: all 0.28s cubic-bezier(0.22, 1, 0.36, 1);
		border: 1px solid
			color-mix(in oklab, var(--primary) 18%, var(--line-color));
		backdrop-filter: blur(8px);
		box-shadow:
			0 0 0 1px color-mix(in oklab, var(--primary) 25%, transparent),
			0 8px 24px color-mix(in oklab, var(--primary) 22%, transparent);
	}

	.floating-toc-btn.active {
		background: color-mix(
			in oklab,
			var(--primary) 14%,
			var(--btn-card-bg-active)
		);
		transform: scale(0.94);
	}

	.floating-toc-btn:hover {
		transform: translateY(-1px);
		box-shadow:
			0 0 0 1px color-mix(in oklab, var(--primary) 35%, transparent),
			0 12px 30px color-mix(in oklab, var(--primary) 30%, transparent);
	}

	.progress-ring {
		position: absolute;
		top: 0;
		left: 0;
		transform: rotate(-90deg);
		pointer-events: none;
		z-index: 0;
	}

	.progress-ring-circle {
		stroke: var(--primary);
		stroke-width: 5;
		stroke-dasharray: 251.2;
		stroke-dashoffset: 251.2;
		transition: stroke-dashoffset 0.1s linear;
		stroke-linecap: round;
	}

	.btn-icon {
		z-index: 1;
		position: relative;
	}

	.floating-toc-panel {
		position: absolute;
		bottom: 4.5rem;
		left: var(--floating-toc-panel-left);
		right: var(--floating-toc-panel-right);
		width: 18rem;
		max-height: 60vh;
		background: linear-gradient(
			180deg,
			color-mix(in oklab, var(--primary) 6%, var(--card-bg)) 0%,
			var(--card-bg) 35%
		);
		border: 1px solid
			color-mix(in oklab, var(--primary) 20%, var(--line-color));
		border-radius: 1.05rem;
		box-shadow:
			0 0 0 1px color-mix(in oklab, var(--primary) 12%, transparent),
			0 14px 32px color-mix(in oklab, black 18%, transparent);
		backdrop-filter: blur(10px);
		overflow: hidden;
		opacity: 0;
		visibility: hidden;
		transform: translateY(10px) scale(0.95);
		transition: all 0.24s cubic-bezier(0.22, 1, 0.36, 1);
		pointer-events: none;
	}

	.floating-toc-panel.show {
		opacity: 1;
		visibility: visible;
		transform: translateY(0) scale(1);
		pointer-events: auto;
	}

	.floating-toc-panel-title {
		height: 2.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 0 0.9rem;
		font-size: 0.9rem;
		font-weight: 700;
		text-shadow: 0 1px 0 color-mix(in oklab, white 12%, transparent);
		color: var(--primary);
		border-bottom: 1px solid
			color-mix(in oklab, var(--primary) 18%, var(--line-color));
		background: color-mix(in oklab, var(--primary) 8%, var(--card-bg));
		letter-spacing: 0.02em;
		gap: 0;
		border-left: 0;
		border-right: 0;
		border-top: 0;
		appearance: none;
		cursor: pointer;
		transition: background 0.2s ease;
	}

	.floating-toc-panel-title:hover {
		background: color-mix(in oklab, var(--primary) 12%, var(--card-bg));
	}

	.floating-toc-panel-title-dot {
		display: none;
	}

	.floating-toc-panel-content {
		padding: 0.65rem;
		max-height: calc(60vh - 2.5rem);
		overflow-y: auto;
		overflow-x: hidden;
	}

	.floating-toc-panel-content::-webkit-scrollbar {
		width: 6px;
	}

	.floating-toc-panel-content::-webkit-scrollbar-track {
		background: transparent;
	}

	.floating-toc-panel-content::-webkit-scrollbar-thumb {
		background: color-mix(in oklab, var(--primary) 28%, var(--line-color));
		border-radius: 999px;
		border: 1px solid color-mix(in oklab, var(--primary) 22%, transparent);
	}

	/* @media (max-width: 1920px) {
		.floating-toc-btn {
			box-shadow:
				0 0 0 1px var(--btn-regular-bg),
				0 0 1em var(--btn-regular-bg);
		}
	} */

	@media (max-width: 768px) {
		.floating-toc-wrapper {
			--floating-toc-left: var(--floating-toc-left-mobile);
			--floating-toc-right: var(--floating-toc-right-mobile);
			--floating-toc-bottom: var(--floating-toc-bottom-mobile);
			--floating-toc-panel-left: var(--floating-toc-panel-left-mobile);
			--floating-toc-panel-right: var(--floating-toc-panel-right-mobile);
			transform: none;
			/* opacity: 0.6; */
		}

		.floating-toc-wrapper:active,
		.floating-toc-wrapper.active {
			opacity: 1;
		}

		.floating-toc-panel {
			width: 85vw;
			max-width: 20rem;
			bottom: 4.5rem;
		}
	}

	:global(.floating-toc-item) {
		display: flex;
		align-items: center;
		position: relative;
		padding: 0.48rem 0.52rem;
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 0.9rem;
		line-height: 1.5;
		border-radius: 0.62rem;
		transition: all 0.22s cubic-bezier(0.22, 1, 0.36, 1);
		border: 1px solid transparent;
	}

	:global(.floating-toc-item:hover) {
		background: color-mix(
			in oklab,
			var(--primary) 10%,
			var(--btn-regular-bg)
		);
		color: var(--primary);
		transform: translateX(3px);
		border-color: color-mix(in oklab, var(--primary) 20%, transparent);
	}

	:global(.floating-toc-item.active) {
		background: color-mix(
			in oklab,
			var(--primary) 16%,
			var(--btn-card-bg-active)
		);
		color: var(--primary);
		font-weight: 600;
		border-color: color-mix(in oklab, var(--primary) 34%, transparent);
		box-shadow: inset 0 0 0 1px
			color-mix(in oklab, var(--primary) 20%, transparent);
	}

	:global(.floating-toc-item.active)::before {
		content: "";
		position: absolute;
		left: 0.2rem;
		top: 0.4rem;
		bottom: 0.4rem;
		width: 0.16rem;
		border-radius: 999px;
		background: var(--primary);
		opacity: 0.92;
	}

	:global(.floating-toc-badge) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.25rem;
		height: 1.25rem;
		background: color-mix(
			in oklab,
			var(--primary) 16%,
			var(--btn-regular-bg)
		);
		color: var(--primary);
		border-radius: 0.25rem;
		font-size: 0.75rem;
		font-weight: bold;
		margin-right: 0.5rem;
		flex-shrink: 0;
	}

	:global(.floating-toc-dot) {
		width: 0.5rem;
		height: 0.5rem;
		background: var(--line-divider);
		border-radius: 50%;
		margin-right: 0.75rem;
		margin-left: 0.375rem;
		flex-shrink: 0;
	}

	:global(.floating-toc-dot-small) {
		width: 0.35rem;
		height: 0.35rem;
		background: var(--line-divider);
		border-radius: 50%;
		margin-right: 0.75rem;
		margin-left: 0.45rem;
		flex-shrink: 0;
	}

	:global(.floating-toc-item.active .floating-toc-dot),
	:global(.floating-toc-item.active .floating-toc-dot-small) {
		background: var(--primary);
	}

	:global(.floating-toc-text) {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		letter-spacing: 0.01em;
	}
</style>

<script>
	class FloatingTOC {
		private btn: HTMLElement | null;
		private panel: HTMLElement | null;
		private content: HTMLElement | null;
		private wrapper: HTMLElement | null;
		private title: HTMLElement | null;
		private isOpen = false;
		private observer: MutationObserver | null = null;
		private headings: HTMLElement[] = [];
		private mode: "headings" | "posts" | "none" = "none";
		private readonly onScroll: () => void;
		private readonly onResize: () => void;
		private readonly onBtnClick: (e: Event) => void;
		private readonly onDocumentClick: (e: Event) => void;
		private readonly onContentClick: (e: Event) => void;
		private readonly onTitleClick: (e: Event) => void;
		private readonly onKeyDown: (e: KeyboardEvent) => void;

		constructor() {
			this.btn = document.getElementById("floating-toc-btn");
			this.panel = document.getElementById("floating-toc-panel");
			this.content = document.getElementById("floating-toc-content");
			this.wrapper = document.querySelector(".floating-toc-wrapper");
			this.title = document.getElementById("floating-toc-title");
			this.onScroll = () => {
				this.updateProgress();
				this.updateActiveHeading();
			};
			this.onResize = () => {
				this.updateActiveHeading();
				this.updateProgress();
			};
			this.onBtnClick = (e) => {
				e.stopPropagation();
				this.toggle();
			};
			this.onDocumentClick = (e) => {
				if (this.isOpen && !this.wrapper?.contains(e.target as Node)) {
					this.close();
				}
			};
			this.onContentClick = (e) => {
				const link = (e.target as HTMLElement).closest("a");
				if (!link) return;

				const href = link.getAttribute("href") || "";
				if (href.startsWith("#")) {
					e.preventDefault();
					const id = href.slice(1);
					if (id) {
						const element = document.getElementById(id);
						if (element) {
							const top =
								element.getBoundingClientRect().top +
								window.scrollY -
								120;
							window.scrollTo({ top, behavior: "smooth" });
						}
					}
					return;
				}

				if (href) {
					const swup = (window as any).swup;
					if (swup && typeof swup.navigate === "function") {
						e.preventDefault();
						swup.navigate(href);
					}
					this.close();
				}
			};
			this.onKeyDown = (e) => {
				if (e.key === "Escape" && this.isOpen) this.close();
			};
			this.onTitleClick = (e) => {
				e.preventDefault();
				e.stopPropagation();
				window.scrollTo({ top: 0, behavior: "smooth" });
				this.close();
			};

			this.init();
		}

		private init() {
			window.addEventListener("scroll", this.onScroll, { passive: true });
			window.addEventListener("resize", this.onResize, { passive: true });

			this.bindEvents();
			this.generateTOC();
			this.observeContent();
			this.updateProgress();
		}

		private observeContent() {
			const contentWrapper =
				document.getElementById("content-wrapper") ||
				document.getElementById("swup-container") ||
				document.body;
			if (contentWrapper) {
				this.observer = new MutationObserver(() => {
					this.generateTOC();
					this.updateProgress();
				});
				this.observer.observe(contentWrapper, {
					childList: true,
					subtree: true,
				});
			}
		}

		private updateProgress() {
			if (!this.btn) return;

			const scrollTop =
				window.scrollY || document.documentElement.scrollTop;
			const docHeight =
				document.documentElement.scrollHeight -
				document.documentElement.clientHeight;
			const scrollPercent = docHeight > 0 ? scrollTop / docHeight : 0;

			const circle = this.btn.querySelector(
				".progress-ring-circle",
			) as SVGCircleElement;
			if (circle) {
				const radius = circle.r.baseVal.value;
				const circumference = radius * 2 * Math.PI;
				const offset = Math.max(
					0,
					Math.min(
						circumference,
						circumference - scrollPercent * circumference,
					),
				);
				circle.style.strokeDashoffset = offset.toString();
			}
		}

		private updateActiveHeading() {
			if (!this.content || this.mode !== "headings") return;

			// 不显示“当前所在位置”，统一移除目录项高亮状态
			const links = this.content.querySelectorAll(".floating-toc-item");
			links.forEach((link) => link.classList.remove("active"));
		}

		private generateTOC() {
			const emptyStateHTML = `
				<div class="floating-toc-item" style="justify-content: center;text-align: center; pointer-events: none; opacity: 0.5;">
					<span class="floating-toc-text">暂无目录</span>
				</div>
			`;

			const path = window.location.pathname;
			const isHomePage = path === "/" || /^\/\d+\/?$/.test(path);
			if (isHomePage && this.renderHomePostList()) {
				return;
			}

			const allHeadings = this.getHeadingElements();
			if (allHeadings.length === 0) {
				this.wrapper?.classList.remove("active-toc");
				this.wrapper?.classList.add("no-toc");
				this.headings = [];
				this.mode = "none";
				if (this.content) {
					this.content.innerHTML = emptyStateHTML;
				}
				return;
			}

			this.wrapper?.classList.remove("no-toc");
			this.wrapper?.classList.add("active-toc");
			this.headings = [];
			this.mode = "headings";

			const maxLevel = parseInt(this.wrapper?.dataset.depth || "3");
			const useJapaneseBadge =
				this.wrapper?.dataset.japaneseBadge === "true";

			const japaneseKatakana = [
				"ア",
				"イ",
				"ウ",
				"エ",
				"オ",
				"カ",
				"キ",
				"ク",
				"ケ",
				"コ",
				"サ",
				"シ",
				"ス",
				"セ",
				"ソ",
				"タ",
				"チ",
				"ツ",
				"テ",
				"ト",
				"ナ",
				"ニ",
				"ヌ",
				"ネ",
				"ノ",
				"ハ",
				"ヒ",
				"フ",
				"ヘ",
				"ホ",
			];

			let minLevel = 6;
			allHeadings.forEach((h) => {
				const level = parseInt(h.tagName[1]);
				if (level < minLevel) minLevel = level;
			});

			let html = "";
			let h1Count = 0;
			allHeadings.forEach((heading) => {
				const level = parseInt(heading.tagName[1]);

				if (level >= minLevel + maxLevel) return;

				this.headings.push(heading as HTMLElement);

				const indent = (level - minLevel) * 1;
				let badge = "";

				if (level === minLevel) {
					h1Count++;
					const badgeText =
						useJapaneseBadge &&
						h1Count - 1 < japaneseKatakana.length
							? japaneseKatakana[h1Count - 1]
							: h1Count.toString();
					badge = `<span class="floating-toc-badge">${badgeText}</span>`;
				} else if (level === minLevel + 1) {
					badge = '<span class="floating-toc-dot"></span>';
				} else {
					badge = '<span class="floating-toc-dot-small"></span>';
				}

				const text = (heading.textContent || "").replace(/#+\s*$/, "");
				html += `<a href="#${heading.id}" class="floating-toc-item" style="padding-left: ${0.5 + indent}rem" data-level="${level - minLevel}">${badge}<span class="floating-toc-text">${text}</span></a>`;
			});

			if (this.content) {
				this.content.innerHTML = html;
			}

			this.updateActiveHeading();
		}

		private getHeadingElements() {
			const selectors = [
				"#post-container",
				".custom-md",
				".markdown-content",
				"#content-wrapper",
			];
			for (const selector of selectors) {
				const container = document.querySelector(selector);
				if (!container) continue;
				const headings = container.querySelectorAll(
					"h1[id], h2[id], h3[id], h4[id], h5[id], h6[id]",
				);
				if (headings.length > 0) return headings;
			}
			return document.querySelectorAll(
				"h1[id], h2[id], h3[id], h4[id], h5[id], h6[id]",
			);
		}

		private renderHomePostList() {
			const postCards = document.querySelectorAll(".card-base");
			const items: Array<{ title: string; url: string }> = [];

			postCards.forEach((card, index) => {
				const cardEl = card as HTMLElement;
				if (!cardEl.id) {
					cardEl.id = `home-post-${index + 1}`;
				}

				const titleLink = card.querySelector(
					'a[href*="/posts/"].transition.group, a[href*="/posts/"][aria-label]',
				) as HTMLAnchorElement | null;
				if (!titleLink) return;

				const title =
					titleLink.textContent?.replace(/\s+/g, " ").trim() || "";
				if (title) {
					items.push({ title, url: `#${cardEl.id}` });
				}
			});

			if (items.length === 0 || !this.content) return false;

			this.mode = "posts";
			this.headings = [];
			this.wrapper?.classList.remove("no-toc");
			this.wrapper?.classList.add("active-toc");

			let html = "";
			items.forEach((item, index) => {
				html += `<a href="${item.url}" class="floating-toc-item"><span class="floating-toc-badge">${index + 1}</span><span class="floating-toc-text">${item.title}</span></a>`;
			});
			this.content.innerHTML = html;
			return true;
		}

		private bindEvents() {
			this.btn?.addEventListener("click", this.onBtnClick);
			document.addEventListener("click", this.onDocumentClick);
			this.content?.addEventListener("click", this.onContentClick);
			this.title?.addEventListener("click", this.onTitleClick);
			document.addEventListener("keydown", this.onKeyDown);
		}

		private toggle() {
			this.isOpen ? this.close() : this.open();
		}

		private open() {
			this.isOpen = true;
			this.panel?.classList.add("show");
			this.btn?.classList.add("active");
			this.wrapper?.classList.add("active");
		}

		private close() {
			this.isOpen = false;
			this.panel?.classList.remove("show");
			this.btn?.classList.remove("active");
			this.wrapper?.classList.remove("active");
		}

		public destroy() {
			if (this.observer) {
				this.observer.disconnect();
				this.observer = null;
			}
			window.removeEventListener("scroll", this.onScroll);
			window.removeEventListener("resize", this.onResize);
			this.btn?.removeEventListener("click", this.onBtnClick);
			this.content?.removeEventListener("click", this.onContentClick);
			this.title?.removeEventListener("click", this.onTitleClick);
			document.removeEventListener("click", this.onDocumentClick);
			document.removeEventListener("keydown", this.onKeyDown);
			this.close();
		}
	}

	const FLOATING_TOC_INSTANCE_KEY = "__mizukiFloatingTOCInstance";
	const FLOATING_TOC_BOOTSTRAPPED_KEY = "__mizukiFloatingTOCBootstrapped";

	function mountFloatingTOC() {
		const prev = (window as any)[FLOATING_TOC_INSTANCE_KEY] as
			| FloatingTOC
			| undefined;
		if (prev) {
			prev.destroy();
		}
		(window as any)[FLOATING_TOC_INSTANCE_KEY] = new FloatingTOC();
	}

	function bootstrapFloatingTOC() {
		mountFloatingTOC();
		document.addEventListener("swup:page:view", mountFloatingTOC);
	}

	if (!(window as any)[FLOATING_TOC_BOOTSTRAPPED_KEY]) {
		(window as any)[FLOATING_TOC_BOOTSTRAPPED_KEY] = true;
		if (document.readyState === "loading") {
			document.addEventListener(
				"DOMContentLoaded",
				bootstrapFloatingTOC,
				{
					once: true,
				},
			);
		} else {
			bootstrapFloatingTOC();
		}
	}
</script>
