---
import { Icon } from "astro-icon/components";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

const backToTopLabel = i18n(I18nKey.backToTop);
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<div class="back-to-top-wrapper block">
	<button
		id="back-to-top-btn"
		class="back-to-top-btn hide"
		onclick="backToTop()"
		aria-label={backToTopLabel}
		title={backToTopLabel}
	>
		<Icon
			name="material-symbols:keyboard-arrow-up-rounded"
			class="back-to-top-icon"
		/>
	</button>
</div>

<style lang="stylus">
  .back-to-top-wrapper
    width: 3.75rem
    height: 3.75rem
    position: absolute
    left: 0
    top: 0
    pointer-events: none
    z-index: 45

  .back-to-top-btn
    width: 3.75rem
    height: 3.75rem
    display: flex
    align-items: center
    justify-content: center
    color: var(--primary)
    position: fixed
    bottom: 15rem
    opacity: 1
    left: -4rem
    cursor: pointer
    transform: translateX(5rem)
    pointer-events: auto
    transition: all 0.28s cubic-bezier(0.22, 1, 0.36, 1)
    border: 1px solid color-mix(var(--primary) 18%, var(--line-color))
    border-radius: 1rem
    background: linear-gradient(160deg, color-mix(var(--primary) 12%, var(--card-bg)) 0%, var(--card-bg) 80%)
    backdrop-filter: blur(8px)
    box-shadow: 0 0 0 1px color-mix(var(--primary) 25%, transparent), 0 8px 24px color-mix(var(--primary) 22%, transparent)

    &:hover
      transform: translateX(5rem) translateY(-1px)
      box-shadow: 0 0 0 1px color-mix(var(--primary) 35%, transparent), 0 12px 30px color-mix(var(--primary) 30%, transparent)

    &.hide
      transform: translateX(5rem) scale(0.9)
      opacity: 0
      pointer-events: none
      box-shadow: none

    &:active
      transform: translateX(5rem) scale(0.94)
      background: color-mix(var(--primary) 14%, var(--btn-card-bg-active))

  .back-to-top-icon
    font-size: 2rem

  // 手机端隐藏返回顶部按钮
  // @media (max-width: 768px)
  //   .back-to-top-wrapper
  //     display: none

</style>

<script is:raw is:inline>
	function backToTop() {
		// 直接使用原生滚动，避免OverlayScrollbars冲突
		window.scroll({ top: 0, behavior: "smooth" });
	}
</script>
