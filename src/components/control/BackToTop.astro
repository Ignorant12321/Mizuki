---
import FloatingButton from "@components/common/FloatingButton.astro";
---

<FloatingButton
	id="back-to-top-btn"
	icon="material-symbols:keyboard-arrow-up-rounded"
	ariaLabel="Back to Top"
	onclick="backToTop()"
	class="hide"
/>

<script is:raw is:inline>
	function backToTop() {
		window.scroll({ top: 0, behavior: "smooth" });
	}

	if (typeof window.BackToTopManager === "undefined") {
		window.BackToTopManager = class BackToTopManager {
			constructor() {
				this.button = null;
				this.hasBoundScroll = false;
				this.updateVisibility = this.updateVisibility.bind(this);
			}

			init() {
				this.button = document.getElementById("back-to-top-btn");
				if (!this.button) {
					return;
				}

				if (!this.hasBoundScroll) {
					this.setupScrollListener();
					this.hasBoundScroll = true;
				}

				this.updateVisibility();
			}

			updateVisibility() {
				if (!this.button) {
					return;
				}

				const scrollTop =
					window.pageYOffset ||
					document.documentElement.scrollTop;

				if (scrollTop > 200) {
					this.button.classList.remove("hide");
				} else {
					this.button.classList.add("hide");
				}
			}

			setupScrollListener() {
				window.addEventListener("scroll", this.updateVisibility, {
					passive: true,
				});
			}
		};
	}

	function initBackToTopManager() {
		if (!window.__mizukiBackToTopManager) {
			window.__mizukiBackToTopManager = new window.BackToTopManager();
		}

		window.__mizukiBackToTopManager.init();
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initBackToTopManager, {
			once: true,
		});
	} else {
		initBackToTopManager();
	}

	document.addEventListener("astro:after-swap", initBackToTopManager);
</script>
