---
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

const backToBottomLabel = i18n(I18nKey.backToBottom);
const backToBottomPosition = siteConfig.floatingWidgets?.backToBottom ?? {
	desktop: { left: "-4rem", bottom: "5rem" },
	mobile: { left: "-4rem", bottom: "5rem" },
};
---

<div class="back-to-bottom-wrapper block">
	<button
		id="back-to-bottom-btn"
		class="back-to-bottom-btn"
		onclick="backToBottom()"
		aria-label={backToBottomLabel}
		title={backToBottomLabel}
		style={`--back-to-bottom-left-desktop:${backToBottomPosition.desktop.left};--back-to-bottom-bottom-desktop:${backToBottomPosition.desktop.bottom};--back-to-bottom-left-mobile:${backToBottomPosition.mobile.left};--back-to-bottom-bottom-mobile:${backToBottomPosition.mobile.bottom};`}
	>
		<Icon
			name="material-symbols:keyboard-arrow-down-rounded"
			class="back-to-bottom-icon"
		/>
	</button>
</div>

<style lang="stylus">
  .back-to-bottom-wrapper
    width: 3.75rem
    height: 3.75rem
    position: absolute
    left: 0
    top: 0
    pointer-events: none
    z-index: 45

  .back-to-bottom-btn
    width: 3.75rem
    height: 3.75rem
    display: flex
    align-items: center
    justify-content: center
    color: var(--primary)
    position: fixed
    bottom: var(--back-to-bottom-bottom-desktop)
    opacity: 1
    left: var(--back-to-bottom-left-desktop)
    cursor: pointer
    transform: translateX(5rem)
    pointer-events: auto
    transition: all 0.28s cubic-bezier(0.22, 1, 0.36, 1)
    border: 1px solid var(--line-color)
    border: 1px solid color-mix(var(--primary) 18%, var(--line-color))
    border-radius: 1rem
    background: var(--card-bg)
    background: linear-gradient(160deg, color-mix(var(--primary) 12%, var(--card-bg)) 0%, var(--card-bg) 80%)
    backdrop-filter: blur(8px)
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12)
    box-shadow: 0 0 0 1px color-mix(var(--primary) 25%, transparent), 0 8px 24px color-mix(var(--primary) 22%, transparent)

    &:hover
      transform: translateX(5rem) translateY(-1px)
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.16)
      box-shadow: 0 0 0 1px color-mix(var(--primary) 35%, transparent), 0 12px 30px color-mix(var(--primary) 30%, transparent)

    &.hide
      transform: translateX(5rem) scale(0.9) 
      opacity: 0
      pointer-events: none
      box-shadow: none

    &:active
      transform: translateX(5rem) scale(0.94)
      background: var(--btn-card-bg-active)
      background: color-mix(var(--primary) 14%, var(--btn-card-bg-active))

  .back-to-bottom-icon
    font-size: 2rem

  @media (max-width: 768px)
    .back-to-bottom-btn
      left: var(--back-to-bottom-left-mobile)
      bottom: var(--back-to-bottom-bottom-mobile)

</style>

<script is:raw is:inline>
	function backToBottom() {
		window.scroll({
			top: document.documentElement.scrollHeight,
			behavior: "smooth",
		});
	}
</script>
