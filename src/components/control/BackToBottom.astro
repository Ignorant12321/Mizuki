---
import { Icon } from "astro-icon/components";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

const backToBottomLabel = i18n(I18nKey.backToBottom);
---

<div class="back-to-bottom-wrapper block">
	<div
		id="back-to-bottom-btn"
		class="back-to-bottom-btn flex items-center rounded-2xl overflow-hidden transition"
		onclick="backToBottom()"
	>
		<button aria-label={backToBottomLabel} title={backToBottomLabel} class="btn-card h-15 w-15">
			<Icon
				name="material-symbols:keyboard-arrow-down-rounded"
				class="mx-auto"
			/>
		</button>
	</div>
</div>

<style lang="stylus">
  .back-to-bottom-wrapper
    width: 3.75rem
    height: 3.75rem
    position: absolute
    left: 0
    top: 0
    pointer-events: none
    z-index: 45

  .back-to-bottom-btn
    color: var(--primary)
    font-size: 2.25rem
    font-weight: bold
    border: none
    position: fixed
    bottom: 5rem
    opacity: 1
    left: -4rem
    cursor: pointer
    transform: translateX(5rem)
    pointer-events: auto
    transition: box-shadow 1s ease-in-out
    box-shadow: 0 0 12px color-mix(var(--primary) 60%, transparent)

    i
      font-size: 1.75rem

    &.hide
      transform: translateX(5rem) scale(0.9) 
      opacity: 0
      pointer-events: none
      box-shadow: none

    &:active
      transform: translateX(5rem) scale(0.9) 

</style>

<script is:raw is:inline>
	function backToBottom() {
		window.scroll({
			top: document.documentElement.scrollHeight,
			behavior: "smooth",
		});
	}
</script>
