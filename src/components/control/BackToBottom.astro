---
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

const backToBottomLabel = i18n(I18nKey.backToBottom);
const backToBottomPosition = siteConfig.floatingWidgets?.backToBottom ?? {
	desktop: { side: "left", offset: "-4rem", bottom: "5rem" },
	mobile: { side: "left", offset: "-4rem", bottom: "5rem" },
};
const backToBottomStyle = `--back-to-bottom-left-desktop:${backToBottomPosition.desktop.side === "left" ? backToBottomPosition.desktop.offset : "auto"};--back-to-bottom-right-desktop:${backToBottomPosition.desktop.side === "right" ? backToBottomPosition.desktop.offset : "auto"};--back-to-bottom-bottom-desktop:${backToBottomPosition.desktop.bottom};--back-to-bottom-shift-desktop:${backToBottomPosition.desktop.side === "left" ? "5rem" : "-5rem"};--back-to-bottom-left-mobile:${backToBottomPosition.mobile.side === "left" ? backToBottomPosition.mobile.offset : "auto"};--back-to-bottom-right-mobile:${backToBottomPosition.mobile.side === "right" ? backToBottomPosition.mobile.offset : "auto"};--back-to-bottom-bottom-mobile:${backToBottomPosition.mobile.bottom};--back-to-bottom-shift-mobile:0;`;
---

<div class="back-to-bottom-wrapper block">
	<button
		id="back-to-bottom-btn"
		class="back-to-bottom-btn"
		onclick="backToBottom()"
		aria-label={backToBottomLabel}
		title={backToBottomLabel}
		style={backToBottomStyle}
	>
		<Icon
			name="material-symbols:keyboard-arrow-down-rounded"
			class="back-to-bottom-icon"
		/>
	</button>
</div>

<style lang="stylus">
  .back-to-bottom-wrapper
    width: 3.75rem
    height: 3.75rem
    position: absolute
    left: 0
    top: 0
    pointer-events: none
    z-index: 45

  .back-to-bottom-btn
    --back-to-bottom-left: var(--back-to-bottom-left-desktop)
    --back-to-bottom-right: var(--back-to-bottom-right-desktop)
    --back-to-bottom-bottom: var(--back-to-bottom-bottom-desktop)
    --back-to-bottom-shift: var(--back-to-bottom-shift-desktop)
    width: 3.75rem
    height: 3.75rem
    display: flex
    align-items: center
    justify-content: center
    color: var(--primary)
    position: fixed
    bottom: var(--back-to-bottom-bottom)
    opacity: 1
    left: var(--back-to-bottom-left)
    right: var(--back-to-bottom-right)
    cursor: pointer
    transform: translateX(var(--back-to-bottom-shift))
    pointer-events: auto
    transition: all 0.28s cubic-bezier(0.22, 1, 0.36, 1)
    border: 1px solid var(--line-color)
    border: 1px solid color-mix(var(--primary) 18%, var(--line-color))
    border-radius: 1rem
    background: var(--card-bg)
    background: linear-gradient(160deg, color-mix(var(--primary) 12%, var(--card-bg)) 0%, var(--card-bg) 80%)
    backdrop-filter: blur(8px)
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12)
    box-shadow: 0 0 0 1px color-mix(var(--primary) 25%, transparent), 0 8px 24px color-mix(var(--primary) 22%, transparent)

    &:hover
      transform: translateX(var(--back-to-bottom-shift)) translateY(-1px)
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.16)
      box-shadow: 0 0 0 1px color-mix(var(--primary) 35%, transparent), 0 12px 30px color-mix(var(--primary) 30%, transparent)

    &.hide
      transform: translateX(var(--back-to-bottom-shift)) scale(0.9) 
      opacity: 0
      pointer-events: none
      box-shadow: none

    &:active
      transform: translateX(var(--back-to-bottom-shift)) scale(0.94)
      background: var(--btn-card-bg-active)
      background: color-mix(var(--primary) 14%, var(--btn-card-bg-active))

  .back-to-bottom-icon
    font-size: 2rem

  @media (max-width: 768px)
    .back-to-bottom-btn
      --back-to-bottom-left: var(--back-to-bottom-left-mobile)
      --back-to-bottom-right: var(--back-to-bottom-right-mobile)
      --back-to-bottom-bottom: var(--back-to-bottom-bottom-mobile)
      --back-to-bottom-shift: var(--back-to-bottom-shift-mobile)

</style>

<script is:raw is:inline>
	function backToBottom() {
		const commentSubmitButton = document.querySelector(
			".tk-submit.tk-fade-in",
		);
		if (commentSubmitButton instanceof HTMLElement) {
			const style = window.getComputedStyle(commentSubmitButton);
			const isVisible =
				style.display !== "none" &&
				style.visibility !== "hidden" &&
				commentSubmitButton.getClientRects().length > 0;

			if (isVisible) {
				commentSubmitButton.scrollIntoView({
					behavior: "smooth",
					block: "end",
				});
				return;
			}
		}

		window.scroll({
			top: document.documentElement.scrollHeight,
			behavior: "smooth",
		});
	}
</script>
