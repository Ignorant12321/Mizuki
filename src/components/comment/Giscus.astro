---
import { commentConfig } from "@/config";
import { PageHeader } from "@/components/features/page-header";

interface Props {
	path: string;
}

const config = {
	...commentConfig.giscus,
	term: Astro.props.path,
};
---

<section class="giscus-comment">
	<PageHeader
		class="giscus-header"
		title="繁星回音"
		subtitle="STARRY ECHOES"
		watermark="COMMENTS"
		divider={false}
	/>

	<div class="giscus-panel">
		<div id="giscus-container" class="giscus-container"></div>
	</div>
</section>

<script is:inline define:vars={{ config }}>
	(function () {
		const GISCUS_CONTAINER_ID = "giscus-container";
		const ROOT_MARGIN = "200px";

		let observer = null;
		let themeObserver = null;
		let swupReplaceHandler = null;
		let swupEnableHandler = null;

		function getCurrentPath() {
			const pathname = window.location.pathname;
			return pathname.endsWith("/") && pathname.length > 1
				? pathname.slice(0, -1)
				: pathname;
		}

		function getThemeValue() {
			if (config.theme !== "preferred_color_scheme") {
				return config.theme;
			}

			const isDark =
				document.documentElement.classList.contains("dark") ||
				document.documentElement.getAttribute("data-theme")?.includes("dark");
			return isDark ? "dark" : "light";
		}

		async function initGiscus() {
			const container = document.getElementById(GISCUS_CONTAINER_ID);
			if (!container) {
				return;
			}

			const theme = getThemeValue();

			container.innerHTML = "";

			const script = document.createElement("script");
			script.src = "https://giscus.app/client.js";
			script.setAttribute("data-repo", config.repo);
			script.setAttribute("data-repo-id", config.repoId);
			script.setAttribute("data-category", config.category);
			script.setAttribute("data-category-id", config.categoryId);
			script.setAttribute("data-mapping", config.mapping);
			script.setAttribute("data-term", getCurrentPath());
			script.setAttribute("data-strict", config.strict);
			script.setAttribute(
				"data-reactions-enabled",
				config.reactionsEnabled,
			);
			script.setAttribute("data-emit-metadata", config.emitMetadata);
			script.setAttribute("data-input-position", config.inputPosition);
			script.setAttribute("data-theme", theme);
			script.setAttribute(
				"data-lang",
				config.lang ? config.lang.replace("_", "-") : "en",
			);
			script.setAttribute("data-loading", config.loading);
			script.crossOrigin = "anonymous";
			script.async = true;

			container.appendChild(script);
		}

		function cleanup() {
			if (observer) {
				observer.disconnect();
				observer = null;
			}
			if (themeObserver) {
				themeObserver.disconnect();
				themeObserver = null;
			}
			if (window.swup?.hooks) {
				if (swupReplaceHandler) {
					window.swup.hooks.off(
						"content:replace",
						swupReplaceHandler,
					);
					swupReplaceHandler = null;
				}
			}
			if (swupEnableHandler) {
				document.removeEventListener("swup:enable", swupEnableHandler);
				swupEnableHandler = null;
			}
		}

		function setupLazyLoad() {
			const container = document.getElementById(GISCUS_CONTAINER_ID);
			if (!container) {
				return;
			}

			if (observer) {
				observer.disconnect();
				observer = null;
			}

			observer = new IntersectionObserver(
				(entries) => {
					if (entries[0].isIntersecting) {
						observer.disconnect();
						observer = null;
						initGiscus();
					}
				},
				{ rootMargin: ROOT_MARGIN },
			);

			observer.observe(container);
		}

		function setupSwupHooks() {
			if (window.swup?.hooks) {
				if (!swupReplaceHandler) {
					swupReplaceHandler = () => {
						setTimeout(setupLazyLoad, 200);
					};
					window.swup.hooks.on("content:replace", swupReplaceHandler);
				}
			} else if (!swupEnableHandler) {
				swupEnableHandler = () => {
					if (window.swup?.hooks && !swupReplaceHandler) {
						swupReplaceHandler = () => {
							setTimeout(setupLazyLoad, 200);
						};
						window.swup.hooks.on(
							"content:replace",
							swupReplaceHandler,
						);
					}
				};
				document.addEventListener("swup:enable", swupEnableHandler, {
					once: true,
				});
			}
		}

		document.addEventListener("mizuki:page:loaded", () => {
			setupLazyLoad();
		});

		window.addEventListener("beforeunload", cleanup);

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", () => {
				setupLazyLoad();
				setupSwupHooks();
			});
		} else {
			setupLazyLoad();
			setupSwupHooks();
		}

		themeObserver = new MutationObserver((mutations) => {
			mutations.forEach((mutation) => {
				if (
					mutation.attributeName === "class" ||
					mutation.attributeName === "data-theme"
				) {
					const iframe = document.querySelector(
						"iframe.giscus-frame",
					);
					if (iframe) {
						iframe.contentWindow?.postMessage(
							{ giscus: { setConfig: { theme: getThemeValue() } } },
							"https://giscus.app",
						);
					}
				}
			});
		});

		themeObserver.observe(document.documentElement, { attributes: true });
	})();
</script>

<style>
	.giscus-comment {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.giscus-header {
		margin-bottom: 0.75rem;
	}

	.giscus-panel {
		position: relative;
		padding: 1rem;
		border: 1px solid
			color-mix(in oklab, var(--line-divider) 82%, var(--primary) 18%);
		border-radius: calc(var(--radius-large) - 0.15rem);
		background: linear-gradient(
			180deg,
			color-mix(in oklab, var(--card-bg) 94%, var(--primary) 6%) 0%,
			var(--card-bg) 100%
		);
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
		transition:
			background-color 0.2s ease,
			border-color 0.2s ease,
			box-shadow 0.2s ease;
	}

	:global(.dark) .giscus-panel {
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.24);
	}

	.giscus-container {
		min-height: 200px;
		width: 100%;
	}

	@media (max-width: 640px) {
		.giscus-panel {
			padding: 0.875rem;
		}
	}
</style>
