---
import { commentConfig } from "@/config";
import CenterTitle from "@/components/CenterTitle.astro";

interface Props {
	path: string;
}

const config = {
	...commentConfig.twikoo,
	el: "#tcomment",
	path: Astro.props.path,
};
---

<CenterTitle title="繁星回音" subtitle="STARRY ECHOES" watermark="ECHOES" />

<div id="tcomment"></div>

<script is:inline src="/scroll-protection.js"></script>
<script
	is:inline
	src="https://s4.zstatic.net/npm/twikoo@1.7.3/dist/twikoo.min.js"></script>
<!-- <script is:inline src="/assets/js/twikoo.min.js"></script> -->
<script is:inline define:vars={{ config }}>
	(() => {
		const STATE_KEY = "twikooPageState";
		if (!window[STATE_KEY]) {
			window[STATE_KEY] = {
				retryCount: 0,
				maxRetries: 8,
				retryTimer: null,
				reinitTimer: null,
				lifecycleListeners: [],
			};
		}
		const state = window[STATE_KEY];

		function normalizePath(path) {
			if (!path) return "/";
			const withLeadingSlash = path.startsWith("/") ? path : "/" + path;
			if (withLeadingSlash.length > 1 && withLeadingSlash.endsWith("/")) {
				return withLeadingSlash.slice(0, -1);
			}
			return withLeadingSlash;
		}

		function getCurrentPath() {
			return normalizePath(window.location.pathname);
		}

		function getCommentPath() {
			return getCurrentPath();
		}

		function clearTimers() {
			if (state.retryTimer) {
				clearTimeout(state.retryTimer);
				state.retryTimer = null;
			}
			if (state.reinitTimer) {
				clearTimeout(state.reinitTimer);
				state.reinitTimer = null;
			}
		}

		function showLoadError(message) {
			const commentEl = document.getElementById("tcomment");
			if (!commentEl) return;
			commentEl.innerHTML =
				'<div class="text-sm text-black/60 dark:text-white/60 py-4">' +
				message +
				"</div>";
		}

		function createTwikooConfig() {
			return {
				...config,
				path: getCommentPath(),
				el: "#tcomment",
			};
		}

		function initTwikoo() {
			const commentEl = document.getElementById("tcomment");
			if (!commentEl) return;

			if (typeof twikoo === "undefined") {
				if (state.retryCount >= state.maxRetries) {
					showLoadError("评论加载失败，请刷新页面后重试。");
					return;
				}
				state.retryCount += 1;
				state.retryTimer = setTimeout(initTwikoo, 500);
				return;
			}

			state.retryCount = 0;
			commentEl.innerHTML = "";
			twikoo.init(createTwikooConfig()).catch((error) => {
				console.error("[Twikoo] 初始化失败:", error);
				showLoadError("评论初始化失败，请稍后重试。");
			});
		}

		function scheduleInit(delay) {
			if (state.reinitTimer) {
				clearTimeout(state.reinitTimer);
			}
			state.reinitTimer = setTimeout(() => {
				state.reinitTimer = null;
				initTwikoo();
			}, delay);
		}

		function cleanupLifecycleListeners() {
			if (!state.lifecycleListeners || state.lifecycleListeners.length === 0) {
				return;
			}
			for (let i = 0; i < state.lifecycleListeners.length; i++) {
				const listener = state.lifecycleListeners[i];
				const target = listener[0];
				const eventName = listener[1];
				const handler = listener[2];
				if (target && target.removeEventListener) {
					target.removeEventListener(eventName, handler);
				}
			}
			state.lifecycleListeners = [];
		}

		function addListener(target, eventName, handler, options) {
			target.addEventListener(eventName, handler, options);
			state.lifecycleListeners.push([target, eventName, handler]);
		}

		function setupLifecycleListeners() {
			cleanupLifecycleListeners();

			const reloadEvents = [
				"swup:contentReplaced",
				"astro:page-load",
				"astro:after-swap",
				"mizuki:page:loaded",
			];

			for (let i = 0; i < reloadEvents.length; i++) {
				const eventName = reloadEvents[i];
				const handler = () => {
					if (document.getElementById("tcomment")) {
						scheduleInit(200);
					}
				};
				addListener(document, eventName, handler);
			}
		}

		clearTimers();
		setupLifecycleListeners();

		if (document.readyState === "loading") {
			const domReadyHandler = () => scheduleInit(0);
			addListener(document, "DOMContentLoaded", domReadyHandler, {
				once: true,
			});
		} else {
			scheduleInit(0);
		}
	})();
</script>
