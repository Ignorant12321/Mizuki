---
interface Props {
	item: {
		id: number;
		title: string;
		siteurl: string;
		imgurl: string;
		desc: string;
		tags: string[];
	};
	visitText?: string;
	copyText?: string;
}

const { item, visitText = "访问", copyText = "复制链接" } = Astro.props;
const hostname = new URL(item.siteurl).hostname;
---

<div
	class="navigation-card group relative bg-transparent rounded-xl border border-black/10 dark:border-white/10 overflow-hidden hover:shadow-lg hover:-translate-y-px"
	data-title={item.title.toLowerCase()}
	data-desc={item.desc.toLowerCase()}
	data-tags={item.tags.join(",")}
>
	<div class="p-4 sm:p-5 flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6">
		<div class="w-16 h-16 sm:w-20 sm:h-20 rounded-xl overflow-hidden transition-all duration-300 shrink-0">
			<img
				src={item.imgurl}
				alt={item.title}
				class="w-full h-full object-contain transform scale-85 group-hover:scale-95 transition-transform duration-300"
				loading="lazy"
			/>
		</div>

		<div class="flex-1 min-w-0">
			<div class="flex items-center gap-2 flex-wrap mb-1">
				<h3 class="text-xl font-bold text-black/90 dark:text-white/90 truncate group-hover:text-[var(--primary)] transition-colors duration-200">
					{item.title}
				</h3>
				{
					item.tags.map((tag) => (
						<span class="px-2 py-0.5 text-[10px] rounded-md bg-[var(--primary)]/10 text-[var(--primary)] font-medium">
							{tag}
						</span>
					))
				}
			</div>
			<a
				href={item.siteurl}
				target="_blank"
				rel="noopener noreferrer"
				class="text-xs text-black/50 dark:text-white/50 hover:text-[var(--primary)] truncate block transition-colors duration-200 mb-1"
			>
				{hostname}
			</a>
			<p class="text-sm text-black/60 dark:text-white/60 line-clamp-1">
				{item.desc}
			</p>
		</div>

		<div class="flex gap-2 w-full sm:w-auto">
			<a
				href={item.siteurl}
				target="_blank"
				rel="noopener noreferrer"
				class="flex-1 sm:flex-none flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-[var(--primary)] text-white hover:bg-[var(--primary)]/90 active:scale-95 transition-all duration-200 font-medium text-sm"
			>
				{visitText}
			</a>
			<button
				class="copy-link-btn px-3 py-2 rounded-lg bg-[var(--btn-regular-bg)] hover:bg-[var(--btn-regular-bg-hover)] active:scale-95 transition-all duration-200 text-black/70 dark:text-white/70"
				data-url={item.siteurl}
				title={copyText}
			>
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
					></path>
				</svg>
			</button>
		</div>
	</div>

	<div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
</div>

<style>
	.navigation-card {
		animation: fadeInUp 0.5s ease-out forwards;
		opacity: 0;
		transition:
			transform 0.34s cubic-bezier(0.16, 1, 0.3, 1),
			box-shadow 0.34s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.18s ease;
	}

	.navigation-card:nth-child(1) {
		animation-delay: 0.05s;
	}
	.navigation-card:nth-child(2) {
		animation-delay: 0.1s;
	}
	.navigation-card:nth-child(3) {
		animation-delay: 0.15s;
	}
	.navigation-card:nth-child(4) {
		animation-delay: 0.2s;
	}
	.navigation-card:nth-child(5) {
		animation-delay: 0.25s;
	}
	.navigation-card:nth-child(6) {
		animation-delay: 0.3s;
	}

	.navigation-card.filtered-out {
		display: none !important;
	}

	.navigation-card.is-filter-hiding,
	.navigation-card.is-filter-showing {
		opacity: 0;
		transform: translateY(6px);
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
