---
import { PageHeader } from "@components/features/page-header";
import MainGridLayout from "@layouts/MainGridLayout.astro";

import { siteConfig } from "../config";
import { newsFeedSources, newsMode } from "../data/news";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

export const prerender = true;

if (!siteConfig.featurePages.news) {
	return Astro.redirect("/404/");
}

const title = siteConfig.news?.title || "时语";
const subtitle = siteConfig.news?.subtitle || "倾听世界之声";
const sourceLabel = i18n(I18nKey.newsSource);
const sourcesLabel = i18n(I18nKey.newsSources);
const emptyTitle = i18n(I18nKey.newsEmpty);
const emptyDescription = i18n(I18nKey.newsEmptyDescription);
const expandLabel = i18n(I18nKey.newsExpand);
const collapseLabel = i18n(I18nKey.newsCollapse);
const loadMoreLabel = i18n(I18nKey.newsLoadMore);
const refreshLabel = i18n(I18nKey.newsRefresh);
const onlineHint = i18n(I18nKey.newsOnlineHint);
const refreshingLabel = i18n(I18nKey.newsRefreshing);
const onlineConfigError = i18n(I18nKey.newsOnlineConfigError);
const localRefreshError = i18n(I18nKey.newsLocalRefreshError);
const refreshFailed = i18n(I18nKey.newsRefreshFailed);
const initialVisible = Math.max(
	1,
	Number(siteConfig.news?.initialVisible ?? 12),
);
const loadMoreStep = Math.max(1, Number(siteConfig.news?.loadMoreStep ?? 12));
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base news-page z-10 px-5 sm:px-8 py-6 relative w-full">
			<PageHeader
				title={title}
				subtitle={subtitle}
				bgImage="https://www.loliapi.com/acg/pc?t=news"
			/>

			<div class="news-toolbar">
				<div class="news-toolbar-head">
					<span class="news-dot"></span>
					<span class="news-toolbar-title">{sourcesLabel}</span>
				</div>
				<div class="news-toolbar-actions">
					<div class="news-sources">
						{
							newsFeedSources.map((source) => (
								<a
									href={source.url}
									target="_blank"
									rel="noopener noreferrer"
									class="news-source-chip"
								>
									{source.name}
								</a>
							))
						}
					</div>
					<button
						id="news-refresh"
						type="button"
						class="news-refresh-btn"
					>
						{refreshLabel}
					</button>
				</div>
				<div
					id="news-status"
					class="news-status"
					style="display: none;"
				>
				</div>
			</div>

			<div id="news-list" class="news-list">
				<div
					class="news-loading"
					id="news-loading"
					style="display: none;"
				>
					<div class="news-loading-title">Loading news...</div>
				</div>
				<div class="news-empty" id="news-empty" style="display: none;">
					<div class="news-empty-title">{emptyTitle}</div>
					<div class="news-empty-desc">{emptyDescription}</div>
				</div>
			</div>

			<div class="news-actions">
				<button
					id="news-load-more"
					type="button"
					class="news-load-more-btn"
					style="display: none;"
				>
					{loadMoreLabel}
				</button>
			</div>
		</div>
	</div>

	<script
		is:inline
		define:vars={{
			expandLabel,
			collapseLabel,
			loadMoreLabel,
			sourceLabel,
			initialVisible,
			loadMoreStep,
			newsMode,
			newsFeedSources,
			onlineHint,
			refreshingLabel,
			onlineConfigError,
			localRefreshError,
			refreshFailed,
		}}
	>
		const INITIAL_VISIBLE = Number(initialVisible) || 12;
		const STEP = Number(loadMoreStep) || 12;
		const OPEN_NEWS_LABEL = "Open news in new tab";
		const LOCAL_ENDPOINT = "/api/news.json";

		const entityMap = {
			amp: "&",
			lt: "<",
			gt: ">",
			quot: '"',
			apos: "'",
			nbsp: " ",
		};

		function decodeEntities(value) {
			return String(value || "")
				.replace(/<!\[CDATA\[([\s\S]*?)\]\]>/g, "$1")
				.replace(/&#(\d+);/g, (_, num) => {
					const code = Number(num);
					return Number.isFinite(code)
						? String.fromCharCode(code)
						: _;
				})
				.replace(/&#x([0-9a-f]+);/gi, (_, hex) => {
					const code = Number.parseInt(hex, 16);
					return Number.isFinite(code)
						? String.fromCharCode(code)
						: _;
				})
				.replace(/&([a-z]+);/gi, (_, name) => entityMap[name] ?? _);
		}

		function stripHtml(value = "") {
			return decodeEntities(value)
				.replace(/<[^>]*>/g, " ")
				.replace(/\s+/g, " ")
				.trim();
		}

		function extractTagValues(xml, tag) {
			const pattern = new RegExp(
				`<${tag}\\b[^>]*>([\\s\\S]*?)<\\/${tag}>`,
				"gi",
			);
			const values = [];

			for (const match of xml.matchAll(pattern)) {
				if (typeof match[1] === "string") {
					values.push(match[1]);
				}
			}

			return values;
		}

		function extractFirstTag(xml, tag) {
			const values = extractTagValues(xml, tag);
			return values.length > 0 ? values[0] : "";
		}

		function resolveLink(link, baseUrl) {
			if (!link) {
				return "#";
			}

			try {
				return new URL(link, baseUrl).href;
			} catch {
				return link;
			}
		}

		function toTimeValue(dateStr) {
			if (!dateStr) {
				return 0;
			}

			const time = new Date(dateStr).getTime();
			return Number.isFinite(time) ? time : 0;
		}

		async function fetchFeedSource(source) {
			const response = await fetch(source.url, { cache: "no-store" });
			if (!response.ok) {
				throw new Error(`Failed to fetch RSS: ${response.status}`);
			}

			const xml = await response.text();
			const itemXmlList = xml.match(/<item\b[\s\S]*?<\/item>/gi) ?? [];

			return itemXmlList
				.map((itemXml) => {
					const title =
						stripHtml(extractFirstTag(itemXml, "title")) ||
						"无标题";
					const link =
						decodeEntities(extractFirstTag(itemXml, "link")) ||
						decodeEntities(extractFirstTag(itemXml, "guid"));
					const pubDate = stripHtml(
						extractFirstTag(itemXml, "pubDate"),
					);
					const description = stripHtml(
						extractFirstTag(itemXml, "description"),
					);
					const categoryValues = extractTagValues(itemXml, "category")
						.map((value) => stripHtml(value))
						.filter(Boolean);

					return {
						title,
						link: resolveLink(link, source.url),
						pubDate,
						description,
						category:
							categoryValues.length > 0
								? Array.from(new Set(categoryValues)).join(
										" / ",
									)
								: "",
						sourceName: source.name,
					};
				})
				.filter((item) => item.title && item.link);
		}

		async function fetchOnlineNews() {
			const results = await Promise.allSettled(
				newsFeedSources.map((source) => fetchFeedSource(source)),
			);
			const merged = results
				.filter((result) => result.status === "fulfilled")
				.flatMap((result) => result.value);

			if (merged.length === 0) {
				throw new Error("No online feeds could be fetched");
			}

			const deduped = Array.from(
				new Map(
					merged.map((item) => [item.link || item.title, item]),
				).values(),
			);

			return deduped.sort(
				(a, b) => toTimeValue(b.pubDate) - toTimeValue(a.pubDate),
			);
		}

		function createNewsCard(item) {
			const article = document.createElement("article");
			article.className = "news-card";
			article.setAttribute("data-news-item", "true");

			const categoryNode = item.category
				? `<span class="news-category-tag"></span>`
				: "";
			const descriptionNode = item.description
				? `<div class="news-desc-wrap"><p class="news-desc" data-news-desc></p><button type="button" class="news-toggle-btn" data-news-toggle data-expanded="false" style="display: none;">${expandLabel}</button></div>`
				: "";

			article.innerHTML = `
				<div class="news-card-inner">
					<div class="news-title-row">
						<h2 class="news-title"></h2>
						<a href="#" target="_blank" rel="noopener noreferrer" class="news-open-btn" aria-label="${OPEN_NEWS_LABEL}">
							<span class="news-arrow" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M7 17L17 7"></path>
									<path d="M8 7H17V16"></path>
								</svg>
							</span>
						</a>
					</div>
					<div class="news-meta">
						<time></time>
						<span class="news-source-tag"></span>
						${categoryNode}
					</div>
					${descriptionNode}
				</div>
			`;

			const titleEl = article.querySelector(".news-title");
			const openBtn = article.querySelector(".news-open-btn");
			const timeEl = article.querySelector("time");
			const sourceEl = article.querySelector(".news-source-tag");
			const categoryEl = article.querySelector(".news-category-tag");
			const descEl = article.querySelector("[data-news-desc]");

			if (titleEl) {
				titleEl.textContent = item.title || "";
			}
			if (openBtn) {
				openBtn.href = item.link || "#";
			}
			if (timeEl) {
				timeEl.textContent = item.pubDate || "";
				if (item.pubDate) {
					timeEl.setAttribute("datetime", item.pubDate);
				} else {
					timeEl.remove();
				}
			}
			if (sourceEl) {
				sourceEl.textContent = `${sourceLabel} · ${item.sourceName || ""}`;
			}
			if (categoryEl) {
				if (item.category) {
					categoryEl.textContent = item.category;
				} else {
					categoryEl.remove();
				}
			}
			if (descEl && item.description) {
				descEl.textContent = item.description;
			}

			return article;
		}

		function setupDescriptions(scope = document) {
			const descElements = Array.from(
				scope.querySelectorAll("[data-news-desc]"),
			);

			descElements.forEach((descEl) => {
				const toggleBtn =
					descEl.parentElement?.querySelector("[data-news-toggle]");
				if (!toggleBtn) {
					return;
				}

				const lineHeight = Number.parseFloat(
					window.getComputedStyle(descEl).lineHeight,
				);
				const collapsedHeight = Number.isFinite(lineHeight)
					? Math.round(lineHeight * 3)
					: 84;
				const naturalHeight = descEl.scrollHeight;

				if (naturalHeight <= collapsedHeight + 4) {
					descEl.style.maxHeight = "";
					descEl.classList.remove("is-collapsed");
					toggleBtn.style.display = "none";
					return;
				}

				descEl.dataset.collapsedHeight = String(collapsedHeight);
				descEl.classList.add("is-collapsed");
				descEl.style.transition = "none";
				descEl.style.maxHeight = `${collapsedHeight}px`;
				requestAnimationFrame(() => {
					descEl.style.transition = "";
				});

				toggleBtn.style.display = "inline-flex";
				toggleBtn.textContent = expandLabel;
				toggleBtn.setAttribute("data-expanded", "false");
				toggleBtn.onclick = () => {
					const expanded =
						toggleBtn.getAttribute("data-expanded") === "true";

					if (!expanded) {
						descEl.classList.remove("is-collapsed");
						const expandedHeight = descEl.scrollHeight;
						descEl.style.maxHeight = `${expandedHeight}px`;
						toggleBtn.setAttribute("data-expanded", "true");
						toggleBtn.textContent = collapseLabel;
						return;
					}

					const currentExpandedHeight = descEl.scrollHeight;
					descEl.style.maxHeight = `${currentExpandedHeight}px`;
					requestAnimationFrame(() => {
						descEl.classList.add("is-collapsed");
						const targetHeight = Number(
							descEl.dataset.collapsedHeight ||
								descEl.clientHeight,
						);
						descEl.style.maxHeight = `${targetHeight}px`;
					});
					toggleBtn.setAttribute("data-expanded", "false");
					toggleBtn.textContent = expandLabel;
				};
			});
		}

		function initNewsPage() {
			const listEl = document.getElementById("news-list");
			const loadingEl = document.getElementById("news-loading");
			const emptyEl = document.getElementById("news-empty");
			const loadMoreBtn = document.getElementById("news-load-more");
			const refreshBtn = document.getElementById("news-refresh");
			const statusEl = document.getElementById("news-status");
			if (!listEl || !refreshBtn) {
				return;
			}

			let cards = [];
			let visibleCount = INITIAL_VISIBLE;
			let isLoading = false;

			function setStatus(message, tone = "info") {
				if (!statusEl) {
					return;
				}

				if (!message) {
					statusEl.textContent = "";
					statusEl.style.display = "none";
					statusEl.dataset.tone = "";
					return;
				}

				statusEl.textContent = message;
				statusEl.dataset.tone = tone;
				statusEl.style.display = "";
			}

			function setLoadingState(loading) {
				isLoading = loading;
				refreshBtn.toggleAttribute("disabled", loading);
				if (loadingEl) {
					loadingEl.style.display = loading ? "" : "none";
				}
			}

			function clearRenderedCards() {
				Array.from(
					listEl.querySelectorAll("[data-news-item='true']"),
				).forEach((node) => node.remove());
				cards = [];
			}

			function refreshLoadMore() {
				if (!loadMoreBtn) {
					return;
				}

				if (visibleCount >= cards.length || cards.length === 0) {
					loadMoreBtn.style.display = "none";
				} else {
					loadMoreBtn.style.display = "";
					loadMoreBtn.textContent = loadMoreLabel;
				}
			}

			function renderList(list) {
				clearRenderedCards();
				visibleCount = INITIAL_VISIBLE;

				if (emptyEl) {
					emptyEl.style.display = list.length === 0 ? "" : "none";
				}

				if (list.length === 0) {
					refreshLoadMore();
					return;
				}

				cards = list.map((item) => createNewsCard(item));
				cards.forEach((card, index) => {
					card.style.display = index < visibleCount ? "" : "none";
					listEl.appendChild(card);
				});

				setupDescriptions(listEl);
				refreshLoadMore();
			}

			async function fetchLocalNews() {
				const response = await fetch(LOCAL_ENDPOINT, {
					cache: "no-store",
				});
				if (!response.ok) {
					throw new Error(
						`Failed to fetch local news: ${response.status}`,
					);
				}

				const data = await response.json();
				return Array.isArray(data?.items) ? data.items : [];
			}

			async function loadNews(mode) {
				if (isLoading) {
					return;
				}

				setLoadingState(true);
				if (emptyEl) {
					emptyEl.style.display = "none";
				}
				setStatus(refreshingLabel, "info");

				try {
					const list =
						mode === "local"
							? await fetchLocalNews()
							: await fetchOnlineNews();
					renderList(list);
					setStatus("", "info");
				} catch {
					if (cards.length === 0 && emptyEl) {
						emptyEl.style.display = "";
					}
					setStatus(refreshFailed, "error");
				} finally {
					setLoadingState(false);
				}
			}

			if (loadMoreBtn) {
				loadMoreBtn.onclick = () => {
					visibleCount += STEP;
					let revealedIndex = 0;
					cards.forEach((card, index) => {
						if (index < visibleCount) {
							const wasHidden = card.style.display === "none";
							card.style.display = "";
							if (wasHidden) {
								card.classList.remove("news-card-enter");
								card.style.animationDelay = `${revealedIndex * 45}ms`;
								revealedIndex += 1;
								requestAnimationFrame(() => {
									card.classList.add("news-card-enter");
								});
							}
						}
					});
					refreshLoadMore();
				};
			}

			refreshBtn.onclick = () => {
				if (newsMode === "local") {
					setStatus(localRefreshError, "error");
					return;
				}

				if (
					!Array.isArray(newsFeedSources) ||
					newsFeedSources.length === 0
				) {
					setStatus(onlineConfigError, "error");
					return;
				}

				void loadNews("online");
			};

			if (newsMode === "local") {
				void loadNews("local");
			} else if (
				!Array.isArray(newsFeedSources) ||
				newsFeedSources.length === 0
			) {
				setStatus(onlineConfigError, "error");
			} else {
				setStatus(onlineHint, "info");
			}
		}

		function bootNewsPage() {
			const listEl = document.getElementById("news-list");
			if (!listEl) {
				return;
			}
			if (listEl.getAttribute("data-news-initialized") === "true") {
				return;
			}
			listEl.setAttribute("data-news-initialized", "true");
			initNewsPage();
		}

		bootNewsPage();
		document.addEventListener("astro:after-swap", () => {
			const listEl = document.getElementById("news-list");
			if (!listEl) {
				return;
			}
			listEl.removeAttribute("data-news-initialized");
			bootNewsPage();
		});
	</script>
</MainGridLayout>

<style is:global>
	.news-loading {
		padding: 1rem;
		border-radius: 1rem;
		border: 1px dashed color-mix(in srgb, var(--primary) 28%, transparent);
		background: color-mix(in srgb, var(--primary) 6%, transparent);
	}

	.news-loading-title {
		font-size: 0.9rem;
		color: var(--text-secondary);
	}

	.news-toolbar {
		position: relative;
		padding: 1rem;
		border-radius: 1rem;
		margin-bottom: 1rem;
		border: 1px solid color-mix(in srgb, var(--primary) 26%, transparent);
		background:
			linear-gradient(
				160deg,
				color-mix(in srgb, var(--primary) 14%, transparent),
				color-mix(in srgb, var(--primary) 2%, transparent) 58%
			),
			var(--card-bg);
	}

	.news-toolbar-head {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 0.7rem;
	}

	.news-toolbar-actions {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		justify-content: space-between;
	}

	.news-dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 999px;
		background: var(--primary);
		box-shadow: 0 0 16px color-mix(in srgb, var(--primary) 60%, transparent);
	}

	.news-toolbar-title {
		font-size: 0.92rem;
		font-weight: 700;
		color: color-mix(in srgb, var(--text-primary) 88%, var(--primary));
	}

	.news-sources {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		flex: 1;
	}

	.news-source-chip {
		display: inline-flex;
		align-items: center;
		padding: 0.3rem 0.65rem;
		border-radius: 999px;
		font-size: 0.78rem;
		text-decoration: none;
		color: color-mix(in srgb, var(--primary) 90%, black 10%);
		background: color-mix(in srgb, var(--primary) 11%, transparent);
		border: 1px solid color-mix(in srgb, var(--primary) 20%, transparent);
		transition:
			border-color 0.18s ease,
			background 0.18s ease;
	}

	.news-source-chip:hover {
		background: color-mix(in srgb, var(--primary) 16%, transparent);
		border-color: color-mix(in srgb, var(--primary) 40%, transparent);
	}

	.news-refresh-btn {
		border: 1px solid color-mix(in srgb, var(--primary) 30%, transparent);
		background: color-mix(in srgb, var(--primary) 10%, transparent);
		color: var(--primary);
		padding: 0.5rem 0.95rem;
		border-radius: 999px;
		font-size: 0.85rem;
		font-weight: 700;
		cursor: pointer;
		white-space: nowrap;
		transition:
			border-color 0.2s ease,
			background 0.2s ease,
			opacity 0.2s ease;
	}

	.news-refresh-btn:hover {
		background: color-mix(in srgb, var(--primary) 16%, transparent);
		border-color: color-mix(in srgb, var(--primary) 45%, transparent);
	}

	.news-refresh-btn:disabled {
		cursor: wait;
		opacity: 0.65;
	}

	.news-status {
		margin-top: 0.8rem;
		padding: 0.75rem 0.9rem;
		border-radius: 0.9rem;
		font-size: 0.86rem;
		line-height: 1.6;
		border: 1px solid transparent;
	}

	.news-status[data-tone="info"] {
		color: color-mix(in srgb, var(--text-primary) 82%, var(--primary));
		background: color-mix(in srgb, var(--primary) 8%, transparent);
		border-color: color-mix(in srgb, var(--primary) 22%, transparent);
	}

	.news-status[data-tone="error"] {
		color: #b42318;
		background: rgba(217, 45, 32, 0.08);
		border-color: rgba(217, 45, 32, 0.18);
	}

	.news-list {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
	}

	.news-card {
		border-radius: 1rem;
		border: 1px solid rgba(0, 0, 0, 0.1);
		background:
			linear-gradient(
				160deg,
				color-mix(in srgb, var(--primary) 6%, transparent),
				transparent 52%
			),
			var(--card-bg);
		box-shadow: 0 10px 26px rgba(0, 0, 0, 0.04);
		transition:
			box-shadow 0.2s ease,
			border-color 0.2s ease,
			background 0.2s ease;
	}

	.news-card.news-card-enter {
		animation: news-card-enter 0.34s cubic-bezier(0.2, 0.8, 0.2, 1) both;
	}

	.news-card:hover {
		box-shadow: 0 10px 26px rgba(0, 0, 0, 0.05);
		border-color: color-mix(in srgb, var(--primary) 45%, transparent);
		background:
			linear-gradient(
				160deg,
				color-mix(in srgb, var(--primary) 10%, transparent),
				transparent 56%
			),
			var(--card-bg);
	}

	.news-card-inner {
		padding: 1rem 1rem 0.9rem;
	}

	.news-title-row {
		display: flex;
		justify-content: space-between;
		gap: 0.85rem;
		align-items: flex-start;
	}

	.news-title {
		margin: 0;
		font-size: 1rem;
		line-height: 1.65;
		color: var(--primary);
		font-weight: 700;
