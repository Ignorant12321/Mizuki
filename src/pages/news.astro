---
import { FilterEmptyState } from "@components/atoms/empty-state";
import { PageHeader } from "@components/features/page-header";
import MainGridLayout from "@layouts/MainGridLayout.astro";

import { siteConfig } from "../config";
import { newsFeedSources, newsMode } from "../data/news";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

export const prerender = true;

if (!siteConfig.featurePages.news) {
	return Astro.redirect("/404/");
}

const title = siteConfig.news?.title || "时语";
const subtitle = siteConfig.news?.subtitle || "倾听世界之声";
const sourceLabel = i18n(I18nKey.newsSource);
const sourcesLabel = i18n(I18nKey.newsSources);
const emptyTitle = i18n(I18nKey.newsEmpty);
const emptyDescription = i18n(I18nKey.newsEmptyDescription);
const expandLabel = i18n(I18nKey.newsExpand);
const collapseLabel = i18n(I18nKey.newsCollapse);
const loadMoreLabel = i18n(I18nKey.newsLoadMore);
const refreshLabel = i18n(I18nKey.newsRefresh);
const onlineHint = i18n(I18nKey.newsOnlineHint);
const refreshingLabel = i18n(I18nKey.newsRefreshing);
const onlineConfigError = i18n(I18nKey.newsOnlineConfigError);
const localRefreshError = i18n(I18nKey.newsLocalRefreshError);
const refreshFailed = i18n(I18nKey.newsRefreshFailed);
const initialVisible = Math.max(
	1,
	Number(siteConfig.news?.initialVisible ?? 12),
);
const loadMoreStep = Math.max(1, Number(siteConfig.news?.loadMoreStep ?? 12));
const siteLang = siteConfig.lang;
const siteTimeZone = siteConfig.timeZone;
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base news-page z-10 px-5 sm:px-8 py-6 relative w-full">
			<PageHeader
				title={title}
				subtitle={subtitle}
				bgImage="https://www.loliapi.com/acg/pc?t=news"
			/>

			<div class="news-toolbar">
				<div class="news-toolbar-head">
					<span class="news-dot"></span>
					<span class="news-toolbar-title">{sourcesLabel}</span>
				</div>
				<div class="news-toolbar-actions">
					<div class="news-sources">
						{
							newsFeedSources.map((source) => (
								<a
									href={source.url}
									target="_blank"
									rel="noopener noreferrer"
									class="news-source-chip"
								>
									{source.name}
								</a>
							))
						}
					</div>
					<button
						id="news-refresh"
						type="button"
						class="news-refresh-btn"
					>
						{refreshLabel}
					</button>
				</div>
				<div
					id="news-status"
					class="news-status"
					style="display: none;"
				>
				</div>
			</div>

			<div id="news-list" class="news-list">
				<div id="no-result" class="hidden">
					<FilterEmptyState
						title={emptyTitle}
						description={emptyDescription}
						compact={false}
					/>
				</div>
			</div>

			<div class="news-actions">
				<button
					id="news-load-more"
					type="button"
					class="news-load-more-btn"
					style="display: none;"
				>
					{loadMoreLabel}
				</button>
			</div>
		</div>
	</div>

	<script
		is:inline
		define:vars={{
			expandLabel,
			collapseLabel,
			loadMoreLabel,
			sourceLabel,
			initialVisible,
			loadMoreStep,
			newsMode,
			newsFeedSources,
			siteLang,
			siteTimeZone,
			onlineHint,
			refreshingLabel,
			onlineConfigError,
			localRefreshError,
			refreshFailed,
		}}
	>
		const INITIAL_VISIBLE = Number(initialVisible) || 12;
		const STEP = Number(loadMoreStep) || 12;
		const OPEN_NEWS_LABEL = "Open news in new tab";
		const LOCAL_ENDPOINT = "/api/news.json";

		const entityMap = {
			amp: "&",
			lt: "<",
			gt: ">",
			quot: '"',
			apos: "'",
			nbsp: " ",
		};

		function decodeEntities(value) {
			return String(value || "")
				.replace(/<!\[CDATA\[([\s\S]*?)\]\]>/g, "$1")
				.replace(/&#(\d+);/g, (_, num) => {
					const code = Number(num);
					return Number.isFinite(code)
						? String.fromCharCode(code)
						: _;
				})
				.replace(/&#x([0-9a-f]+);/gi, (_, hex) => {
					const code = Number.parseInt(hex, 16);
					return Number.isFinite(code)
						? String.fromCharCode(code)
						: _;
				})
				.replace(/&([a-z]+);/gi, (_, name) => entityMap[name] ?? _);
		}

		function stripHtml(value = "") {
			return decodeEntities(value)
				.replace(/<[^>]*>/g, " ")
				.replace(/\s+/g, " ")
				.trim();
		}

		function extractTagValues(xml, tag) {
			const pattern = new RegExp(
				`<${tag}\\b[^>]*>([\\s\\S]*?)<\\/${tag}>`,
				"gi",
			);
			const values = [];

			for (const match of xml.matchAll(pattern)) {
				if (typeof match[1] === "string") {
					values.push(match[1]);
				}
			}

			return values;
		}

		function extractFirstTag(xml, tag) {
			const values = extractTagValues(xml, tag);
			return values.length > 0 ? values[0] : "";
		}

		function resolveLink(link, baseUrl) {
			if (!link) {
				return "#";
			}

			try {
				return new URL(link, baseUrl).href;
			} catch {
				return link;
			}
		}

		function parseGenericRss(xml, source) {
			const itemXmlList = xml.match(/<item\b[\s\S]*?<\/item>/gi) ?? [];
			return itemXmlList
				.map((itemXml) => {
					const title =
						stripHtml(extractFirstTag(itemXml, "title")) ||
						"无标题";
					const link =
						decodeEntities(extractFirstTag(itemXml, "link")) ||
						decodeEntities(extractFirstTag(itemXml, "guid"));
					const pubDate = stripHtml(
						extractFirstTag(itemXml, "pubDate"),
					);
					const description = stripHtml(
						extractFirstTag(itemXml, "description"),
					);
					const categoryValues = extractTagValues(itemXml, "category")
						.map((value) => stripHtml(value))
						.filter(Boolean);

					return {
						title,
						link: resolveLink(link, source.url),
						pubDate,
						description,
						category:
							categoryValues.length > 0
								? Array.from(new Set(categoryValues)).join(
										" / ",
									)
								: "",
						sourceName: source.name,
						sourceUrl: source.url,
					};
				})
				.filter((item) => item.title && item.link);
		}

		function tightenCjkSpacing(value) {
			return String(value || "")
				.replace(/([\u3400-\u9fff])\s+([\u3400-\u9fff])/g, "$1$2")
				.replace(
					/([\u3400-\u9fff])\s+([，。！？；：、）】》])/g,
					"$1$2",
				)
				.replace(/([（【《])\s+([\u3400-\u9fff])/g, "$1$2")
				.replace(
					/([，。！？；：、）】》])\s+([\u3400-\u9fff])/g,
					"$1$2",
				);
		}

		function cleanZaobaoDescription(value) {
			const decoded = decodeEntities(value || "");
			const normalized = decoded
				.replace(/<figure\b[\s\S]*?<\/figure>/gi, "\n")
				.replace(/<br\s*\/?>/gi, "\n")
				.replace(/<\/(p|div|li|h1|h2|h3|h4|h5|h6|blockquote)>/gi, "\n")
				.replace(/<(li)\b[^>]*>/gi, "• ")
				.replace(/<a\b[^>]*>/gi, "")
				.replace(/<\/a>/gi, "")
				.replace(/<[^>]*>/g, " ")
				.replace(/\r\n?/g, "\n")
				.replace(/[ \t]+\n/g, "\n")
				.replace(/\n[ \t]+/g, "\n")
				.replace(/[ \t]{2,}/g, " ")
				.replace(/\n{3,}/g, "\n\n")
				.trim();

			const lines = normalized
				.split("\n")
				.map((line) => tightenCjkSpacing(line.trim()))
				.filter(Boolean)
				.filter((line) => !/^[•·。\-.|]+$/.test(line));

			return lines.join("\n");
		}

		function parseZaobaoFeed(xml, source) {
			const itemXmlList = xml.match(/<item\b[\s\S]*?<\/item>/gi) ?? [];

			return itemXmlList
				.map((itemXml) => {
					const title =
						stripHtml(extractFirstTag(itemXml, "title")) ||
						"无标题";
					const link =
						decodeEntities(extractFirstTag(itemXml, "link")) ||
						decodeEntities(extractFirstTag(itemXml, "guid"));
					const pubDate = stripHtml(
						extractFirstTag(itemXml, "pubDate"),
					);
					const description = cleanZaobaoDescription(
						extractFirstTag(itemXml, "description"),
					);
					const categoryValues = extractTagValues(itemXml, "category")
						.map((value) => stripHtml(value))
						.filter(Boolean);

					return {
						title,
						link: resolveLink(link, source.url),
						pubDate,
						description,
						category:
							categoryValues.length > 0
								? Array.from(new Set(categoryValues)).join(
										" / ",
									)
								: "",
						sourceName: source.name,
						sourceUrl: source.url,
					};
				})
				.filter((item) => item.title && item.link);
		}

		function detectCsdnSectionMarkers(decodedHtml) {
			const headings = Array.from(
				String(decodedHtml || "").matchAll(
					/<h[1-6]\b[^>]*>([\s\S]*?)<\/h[1-6]>/gi,
				),
			)
				.map((match) => stripHtml(match[1] || "").trim())
				.map((line) => line.replace(/\s+/g, " "))
				.filter((line) => line.length >= 2 && line.length <= 16)
				.filter((line) => !line.includes("一分钟速览新闻点"))
				.filter((line) => !line.includes("极客头条"));
			return Array.from(new Set(headings));
		}

		function cleanCsdnDescription(value) {
			const decoded = decodeEntities(value || "");
			const sectionMarkers = detectCsdnSectionMarkers(decoded);
			const withBreaks = decoded
				.replace(/<br\s*\/?>/gi, "\n")
				.replace(/<\/(p|div|li|h1|h2|h3|h4|h5|h6)>/gi, "\n")
				.replace(/<(li)\b[^>]*>/gi, "• ")
				.replace(/<[^>]*>/g, " ");
			const normalized = withBreaks
				.replace(/\r\n?/g, "\n")
				.replace(/[ \t]+\n/g, "\n")
				.replace(/\n[ \t]+/g, "\n")
				.replace(/[ \t]{2,}/g, " ")
				.replace(/\n{3,}/g, "\n\n")
				.trim();

			const splitLines = normalized
				.split("\n")
				.map((line) => line.trim())
				.filter(Boolean)
				.filter((line) => !/^[•·。\-.|]+$/.test(line));

			const uniqueLines = [];
			const seenLines = new Set();
			splitLines.forEach((line) => {
				const n = line.replace(/\s+/g, " ").trim();
				if (!n || seenLines.has(n)) {
					return;
				}
				seenLines.add(n);
				uniqueLines.push(n);
			});

			const quickIndex = uniqueLines.findIndex((line) =>
				line.includes("一分钟速览新闻点"),
			);
			const firstSectionIndex = uniqueLines.findIndex((line) =>
				sectionMarkers.some((marker) => line === marker),
			);

			const intro =
				quickIndex > 0
					? uniqueLines.slice(0, quickIndex).slice(0, 4)
					: uniqueLines.slice(0, Math.min(4, uniqueLines.length));
			const tocStart = quickIndex >= 0 ? quickIndex + 1 : -1;
			const tocEnd =
				firstSectionIndex > tocStart
					? firstSectionIndex
					: uniqueLines.length;
			const toc =
				tocStart >= 0 && tocStart < tocEnd
					? uniqueLines.slice(tocStart, tocEnd).slice(0, 20)
					: [];
			const body =
				firstSectionIndex >= 0
					? uniqueLines.slice(firstSectionIndex).slice(0, 40)
					: uniqueLines
							.slice(Math.max(quickIndex + 1, 0))
							.slice(0, 24);

			const parts = [];
			if (intro.length > 0) {
				parts.push("【导语】");
				parts.push(intro.join("\n"));
			}
			if (toc.length > 0) {
				parts.push("【目录】");
				parts.push(
					toc
						.map((line, index) => `${index + 1}. ${line}`)
						.join("\n"),
				);
			}
			if (body.length > 0) {
				parts.push("【正文】");
				parts.push(body.join("\n\n"));
			}

			return parts.join("\n\n").trim();
		}

		function normalizeCsdnHeading(value) {
			return String(value || "")
				.replace(/^[\d.\-、\s]+/, "")
				.replace(/[“”"'‘’【】《》()（）:：,，。！？!?\-]/g, "")
				.replace(/\s+/g, "")
				.trim()
				.toLowerCase();
		}

		function extractCsdnSections(value) {
			const decoded = decodeEntities(value || "");
			const sectionMarkers = detectCsdnSectionMarkers(decoded);
			const withBreaks = decoded
				.replace(/<br\s*\/?>/gi, "\n")
				.replace(/<\/(p|div|li|h1|h2|h3|h4|h5|h6)>/gi, "\n")
				.replace(/<(li)\b[^>]*>/gi, "• ")
				.replace(/<[^>]*>/g, " ");
			const normalized = withBreaks
				.replace(/\r\n?/g, "\n")
				.replace(/[ \t]+\n/g, "\n")
				.replace(/\n[ \t]+/g, "\n")
				.replace(/[ \t]{2,}/g, " ")
				.replace(/\n{3,}/g, "\n\n")
				.trim();
			const lines = normalized
				.split("\n")
				.map((line) => line.trim())
				.filter(Boolean)
				.filter((line) => !/^[•·。\-.|]+$/.test(line));

			const quickIndex = lines.findIndex((line) =>
				line.includes("一分钟速览新闻点"),
			);
			const firstSectionIndex = lines.findIndex((line) =>
				sectionMarkers.some((marker) => line === marker),
			);
			const intro =
				quickIndex > 0
					? lines.slice(0, quickIndex).slice(0, 4)
					: lines.slice(0, Math.min(4, lines.length));
			const tocStart = quickIndex >= 0 ? quickIndex + 1 : -1;
			const tocEnd =
				firstSectionIndex > tocStart ? firstSectionIndex : lines.length;
			const toc =
				tocStart >= 0 && tocStart < tocEnd
					? Array.from(
							new Set(
								lines
									.slice(tocStart, tocEnd)
									.map((line) =>
										line.replace(/\s+/g, " ").trim(),
									)
									.filter(Boolean),
							),
						).slice(0, 24)
					: [];
			const body =
				firstSectionIndex >= 0
					? lines.slice(firstSectionIndex)
					: lines.slice(Math.max(quickIndex + 1, 0));

			return { intro, toc, body, sectionMarkers };
		}

		function trimCsdnDescription(lines, maxLen = 520) {
			const chunks = [];
			let used = 0;
			for (const line of lines || []) {
				const next = String(line || "").trim();
				if (!next) {
					continue;
				}
				const cost = next.length + (chunks.length > 0 ? 2 : 0);
				if (chunks.length > 0 && used + cost > maxLen) {
					break;
				}
				chunks.push(next);
				used += cost;
			}
			return chunks.join("\n\n").trim();
		}

		function parseCsdnFeed(xml, source) {
			const items = parseGenericRss(xml, source);
			const itemXmlList = xml.match(/<item\b[\s\S]*?<\/item>/gi) ?? [];

			return items.flatMap((item, index) => {
				const itemXml = itemXmlList[index] || "";
				const descriptionRaw = extractFirstTag(itemXml, "description");
				const sections = extractCsdnSections(descriptionRaw);
				const base = {
					...item,
					description: cleanCsdnDescription(descriptionRaw),
				};

				if (sections.toc.length < 3 || sections.body.length === 0) {
					return [base];
				}

				const tocSet = new Set(
					sections.toc.map((title) => normalizeCsdnHeading(title)),
				);
				const bodyBlocks = [];
				let currentSection = "";
				let current = null;

				for (const line of sections.body) {
					if (sections.sectionMarkers.includes(line)) {
						currentSection = line;
						continue;
					}
					const normalized = normalizeCsdnHeading(line);
					if (tocSet.has(normalized)) {
						if (current) {
							bodyBlocks.push(current);
						}
						current = {
							title: line,
							section: currentSection,
							lines: [],
						};
						continue;
					}
					if (current) {
						current.lines.push(line);
					}
				}
				if (current) {
					bodyBlocks.push(current);
				}
				if (bodyBlocks.length < 2) {
					return [base];
				}

				return sections.toc.map((tocTitle, tocIndex) => {
					const tocNormalized = normalizeCsdnHeading(tocTitle);
					const block =
						bodyBlocks.find(
							(itemBlock) =>
								normalizeCsdnHeading(itemBlock.title) ===
									tocNormalized ||
								normalizeCsdnHeading(itemBlock.title).includes(
									tocNormalized,
								) ||
								tocNormalized.includes(
									normalizeCsdnHeading(itemBlock.title),
								),
						) ?? null;

					const descParts = [];
					const shortDesc = trimCsdnDescription(
						block?.lines ?? [],
						520,
					);
					if (shortDesc) {
						descParts.push(shortDesc);
					} else if (sections.intro.length > 0) {
						descParts.push(
							trimCsdnDescription(sections.intro, 280),
						);
					}

					return {
						...base,
						title: tocTitle,
						link: `${base.link}#csdn-item-${tocIndex + 1}`,
						category: block?.section || base.category,
						description: descParts.join("\n\n").trim(),
					};
				});
			});
		}

		function parseBilibiliFeed(xml, source) {
			return parseGenericRss(xml, source).map((item) => ({
				...item,
				category: "",
			}));
		}

		function pickParser(source) {
			const fingerprint = `${String(source.id || "").toLowerCase()} ${String(source.name || "").toLowerCase()} ${String(source.url || "").toLowerCase()}`;
			if (fingerprint.includes("zaobao")) {
				return parseZaobaoFeed;
			}
			if (fingerprint.includes("csdn")) {
				return parseCsdnFeed;
			}
			if (fingerprint.includes("bilibili")) {
				return parseBilibiliFeed;
			}
			return parseGenericRss;
		}

		function toTimeValue(dateStr) {
			if (!dateStr) {
				return 0;
			}

			const time = new Date(dateStr).getTime();
			return Number.isFinite(time) ? time : 0;
		}

		function formatNewsDate(dateStr) {
			if (!dateStr) {
				return "";
			}

			const date = new Date(dateStr);
			if (Number.isNaN(date.getTime())) {
				return stripHtml(dateStr);
			}

			const locale =
				siteLang === "ja"
					? "ja-JP"
					: siteLang === "zh_TW"
						? "zh-TW"
						: siteLang === "en"
							? "en-US"
							: "zh-CN";
			const offset =
				siteTimeZone >= -12 && siteTimeZone <= 12 ? siteTimeZone : 8;
			const siteDate = new Date(date.getTime() + offset * 60 * 60 * 1000);

			return siteDate.toLocaleString(locale, {
				year: "numeric",
				month: "2-digit",
				day: "2-digit",
				hour: "2-digit",
				minute: "2-digit",
				second: "2-digit",
				hour12: false,
				timeZone: "UTC",
			});
		}

		function indentNewsDescription(value) {
			const raw = String(value || "");
			if (!raw) {
				return "";
			}

			return raw
				.split("\n")
				.map((line) => {
					const trimmed = line.trim();
					if (!trimmed) {
						return "";
					}

					const keepUnindented =
						/^【[^】]+】$/.test(trimmed) ||
						/^\d+[.)、]\s*/.test(trimmed) ||
						/^[•·\-]\s*/.test(trimmed);
					if (keepUnindented) {
						return trimmed;
					}

					return `\u3000\u3000${trimmed}`;
				})
				.join("\n");
		}

		async function fetchFeedSource(source) {
			const response = await fetch(source.url, { cache: "no-store" });
			if (!response.ok) {
				throw new Error(`Failed to fetch RSS: ${response.status}`);
			}

			const xml = await response.text();
			const items = pickParser(source)(xml, source);

			return items.map((item) => ({
				...item,
				pubDate: formatNewsDate(item.pubDate),
			}));
		}

		async function fetchOnlineNews() {
			const results = await Promise.allSettled(
				newsFeedSources.map((source) => fetchFeedSource(source)),
			);
			const merged = results
				.filter((result) => result.status === "fulfilled")
				.flatMap((result) => result.value);

			if (merged.length === 0) {
				throw new Error("No online feeds could be fetched");
			}

			const deduped = Array.from(
				new Map(
					merged.map((item) => [item.link || item.title, item]),
				).values(),
			);

			return deduped.sort(
				(a, b) => toTimeValue(b.pubDate) - toTimeValue(a.pubDate),
			);
		}

		function createNewsCard(item) {
			const article = document.createElement("article");
			article.className = "news-card";
			article.setAttribute("data-news-item", "true");

			const categoryNode = item.category
				? `<span class="news-category-tag"></span>`
				: "";
			const descriptionNode = item.description
				? `<div class="news-desc-wrap"><p class="news-desc" data-news-desc></p><button type="button" class="news-toggle-btn" data-news-toggle data-expanded="false" style="display: none;">${expandLabel}</button></div>`
				: "";

			article.innerHTML = `
				<div class="news-card-inner">
					<div class="news-title-row">
						<h2 class="news-title"></h2>
						<a href="#" target="_blank" rel="noopener noreferrer" class="news-open-btn" aria-label="${OPEN_NEWS_LABEL}">
							<span class="news-arrow" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M7 17L17 7"></path>
									<path d="M8 7H17V16"></path>
								</svg>
							</span>
						</a>
					</div>
					<div class="news-meta">
						<time></time>
						<span class="news-source-tag"></span>
						${categoryNode}
					</div>
					${descriptionNode}
				</div>
			`;

			const titleEl = article.querySelector(".news-title");
			const openBtn = article.querySelector(".news-open-btn");
			const timeEl = article.querySelector("time");
			const sourceEl = article.querySelector(".news-source-tag");
			const categoryEl = article.querySelector(".news-category-tag");
			const descEl = article.querySelector("[data-news-desc]");

			if (titleEl) {
				titleEl.textContent = item.title || "";
			}
			if (openBtn) {
				openBtn.href = item.link || "#";
			}
			if (timeEl) {
				timeEl.textContent = item.pubDate || "";
				if (item.pubDate) {
					timeEl.setAttribute("datetime", item.pubDate);
				} else {
					timeEl.remove();
				}
			}
			if (sourceEl) {
				sourceEl.textContent = `${sourceLabel} · ${item.sourceName || ""}`;
			}
			if (categoryEl) {
				if (item.category) {
					categoryEl.textContent = item.category;
				} else {
					categoryEl.remove();
				}
			}
			if (descEl && item.description) {
				descEl.textContent = indentNewsDescription(item.description);
			}

			return article;
		}

		function setupDescriptions(scope = document) {
			const descElements = Array.from(
				scope.querySelectorAll("[data-news-desc]"),
			);

			descElements.forEach((descEl) => {
				const toggleBtn =
					descEl.parentElement?.querySelector("[data-news-toggle]");
				if (!toggleBtn) {
					return;
				}

				const lineHeight = Number.parseFloat(
					window.getComputedStyle(descEl).lineHeight,
				);
				const collapsedHeight = Number.isFinite(lineHeight)
					? Math.round(lineHeight * 3)
					: 84;
				const naturalHeight = descEl.scrollHeight;

				if (naturalHeight <= collapsedHeight + 4) {
					descEl.style.maxHeight = "";
					descEl.classList.remove("is-collapsed");
					toggleBtn.style.display = "none";
					return;
				}

				descEl.dataset.collapsedHeight = String(collapsedHeight);
				descEl.classList.add("is-collapsed");
				descEl.style.transition = "none";
				descEl.style.maxHeight = `${collapsedHeight}px`;
				requestAnimationFrame(() => {
					descEl.style.transition = "";
				});

				toggleBtn.style.display = "inline-flex";
				toggleBtn.textContent = expandLabel;
				toggleBtn.setAttribute("data-expanded", "false");
				toggleBtn.onclick = () => {
					const expanded =
						toggleBtn.getAttribute("data-expanded") === "true";

					if (!expanded) {
						descEl.classList.remove("is-collapsed");
						const expandedHeight = descEl.scrollHeight;
						descEl.style.maxHeight = `${expandedHeight}px`;
						toggleBtn.setAttribute("data-expanded", "true");
						toggleBtn.textContent = collapseLabel;
						return;
					}

					const currentExpandedHeight = descEl.scrollHeight;
					descEl.style.maxHeight = `${currentExpandedHeight}px`;
					requestAnimationFrame(() => {
						descEl.classList.add("is-collapsed");
						const targetHeight = Number(
							descEl.dataset.collapsedHeight ||
								descEl.clientHeight,
						);
						descEl.style.maxHeight = `${targetHeight}px`;
					});
					toggleBtn.setAttribute("data-expanded", "false");
					toggleBtn.textContent = expandLabel;
				};
			});
		}

		function initNewsPage() {
			const listEl = document.getElementById("news-list");
			const emptyEl =
				document.getElementById("no-result") ||
				document.getElementById("no-results");
			const loadMoreBtn = document.getElementById("news-load-more");
			const refreshBtn = document.getElementById("news-refresh");
			const statusEl = document.getElementById("news-status");
			if (!listEl || !refreshBtn) {
				return;
			}

			let cards = [];
			let visibleCount = INITIAL_VISIBLE;
			let isLoading = false;

			function setStatus(message, tone = "info") {
				if (!statusEl) {
					return;
				}

				if (!message) {
					statusEl.textContent = "";
					statusEl.style.display = "none";
					statusEl.dataset.tone = "";
					return;
				}

				statusEl.textContent = message;
				statusEl.dataset.tone = tone;
				statusEl.style.display = "";
			}

			function setLoadingState(loading) {
				isLoading = loading;
				refreshBtn.toggleAttribute("disabled", loading);
			}

			function clearRenderedCards() {
				Array.from(
					listEl.querySelectorAll("[data-news-item='true']"),
				).forEach((node) => node.remove());
				cards = [];
			}

			function refreshLoadMore() {
				if (!loadMoreBtn) {
					return;
				}

				if (visibleCount >= cards.length || cards.length === 0) {
					loadMoreBtn.style.display = "none";
				} else {
					loadMoreBtn.style.display = "";
					loadMoreBtn.textContent = loadMoreLabel;
				}
			}

			function renderList(list) {
				clearRenderedCards();
				visibleCount = INITIAL_VISIBLE;

				emptyEl?.classList.toggle("hidden", list.length > 0);

				if (list.length === 0) {
					refreshLoadMore();
					return;
				}

				cards = list.map((item) => createNewsCard(item));
				cards.forEach((card, index) => {
					card.style.display = index < visibleCount ? "" : "none";
					listEl.appendChild(card);
					if (index < visibleCount) {
						setupDescriptions(card);
					}
				});

				refreshLoadMore();
			}

			async function fetchLocalNews() {
				const response = await fetch(LOCAL_ENDPOINT, {
					cache: "no-store",
				});
				if (!response.ok) {
					throw new Error(
						`Failed to fetch local news: ${response.status}`,
					);
				}

				const data = await response.json();
				return Array.isArray(data?.items) ? data.items : [];
			}

			async function loadNews(mode) {
				if (isLoading) {
					return;
				}

				setLoadingState(true);
				emptyEl?.classList.add("hidden");
				setStatus(refreshingLabel, "info");

				try {
					const list =
						mode === "local"
							? await fetchLocalNews()
							: await fetchOnlineNews();
					renderList(list);
					setStatus("", "info");
				} catch {
					if (cards.length === 0) {
						emptyEl?.classList.remove("hidden");
					}
					setStatus(refreshFailed, "error");
				} finally {
					setLoadingState(false);
				}
			}

			if (loadMoreBtn) {
				loadMoreBtn.onclick = () => {
					visibleCount += STEP;
					let revealedIndex = 0;
					cards.forEach((card, index) => {
						if (index < visibleCount) {
							const wasHidden = card.style.display === "none";
							card.style.display = "";
							if (wasHidden) {
								setupDescriptions(card);
								card.classList.remove("news-card-enter");
								card.style.animationDelay = `${revealedIndex * 45}ms`;
								revealedIndex += 1;
								requestAnimationFrame(() => {
									card.classList.add("news-card-enter");
								});
							}
						}
					});
					refreshLoadMore();
				};
			}

			refreshBtn.onclick = () => {
				if (newsMode === "local") {
					setStatus(localRefreshError, "error");
					return;
				}

				if (
					!Array.isArray(newsFeedSources) ||
					newsFeedSources.length === 0
				) {
					setStatus(onlineConfigError, "error");
					return;
				}

				void loadNews("online");
			};

			if (newsMode === "local") {
				void loadNews("local");
			} else if (
				!Array.isArray(newsFeedSources) ||
				newsFeedSources.length === 0
			) {
				setStatus(onlineConfigError, "error");
			} else {
				setStatus(onlineHint, "info");
			}
		}

		function bootNewsPage() {
			const listEl = document.getElementById("news-list");
			if (!listEl) {
				return;
			}
			if (listEl.getAttribute("data-news-initialized") === "true") {
				return;
			}
			listEl.setAttribute("data-news-initialized", "true");
			initNewsPage();
		}

		bootNewsPage();
		document.addEventListener("astro:after-swap", () => {
			const listEl = document.getElementById("news-list");
			if (!listEl) {
				return;
			}
			listEl.removeAttribute("data-news-initialized");
			bootNewsPage();
		});
	</script>
</MainGridLayout>

