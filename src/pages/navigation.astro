---
import { FilterTabs } from "@components/atoms/filter-tabs";
import { FilterEmptyState } from "@components/atoms/empty-state";
import { PageHeader } from "@components/features/page-header";
import NavigationCard from "@components/features/navigation/NavigationCard.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

import { siteConfig } from "../config";
import { getShuffledNavigationList, tagPriority } from "../data/navigation";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

export const prerender = true;

if (!siteConfig.featurePages.navigation) {
	return Astro.redirect("/404/");
}

const navigationList = getShuffledNavigationList();
const allTags = Array.from(new Set(navigationList.flatMap((item) => item.tags)));
const filterTabs = [
	{
		value: "all",
		label: i18n(I18nKey.navigationFilterAll),
		count: navigationList.length,
	},
	...allTags.map((tag) => ({
		value: tag,
		label: tag,
		count: navigationList.filter((item) => item.tags.includes(tag)).length,
	})),
];
---

<MainGridLayout
	title={i18n(I18nKey.navigation)}
	description={i18n(I18nKey.navigationSubtitle)}
>
	<script is:inline>
		window.isNavigationPage = true;
	</script>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<PageHeader
				title={i18n(I18nKey.navigation)}
				subtitle={i18n(I18nKey.navigationSubtitle)}
				bgImage="https://www.loliapi.com/acg/pc?t=navigation"
			/>

			<div class="mb-6 space-y-3">
				<div class="w-full">
					<div class="relative">
						<input
							type="text"
							id="navigation-search"
							placeholder={i18n(I18nKey.navigationSearchPlaceholder)}
							class="w-full px-4 py-2 pl-10 rounded-lg bg-[var(--btn-regular-bg)]
									text-black/90 dark:text-white/90
									border border-black/10 dark:border-white/10
									focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50
									transition-all duration-200"
						/>
						<svg
							class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-black/40 dark:text-white/40"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
							></path>
						</svg>
					</div>
				</div>

				<FilterTabs
					tabs={filterTabs}
					dataAttr="tags"
					priorityValues={tagPriority}
					emptyTarget="none"
				/>
			</div>

			<div id="navigation-grid" class="grid grid-cols-1 gap-4 mb-6">
				{
					navigationList.map((item) => (
						<NavigationCard
							item={item}
							visitText={i18n(I18nKey.navigationVisit)}
							copyText={i18n(I18nKey.copyLink)}
						/>
					))
				}
			</div>

			<div id="no-results" class="no-results-panel">
				<FilterEmptyState />
			</div>

			<div id="navigation-copy-success-text" style="display: none;">
				{i18n(I18nKey.copied)}
			</div>
		</div>
	</div>

	<script is:inline src="/js/filter-tabs-handler.js"></script>
	<script is:inline src="/js/navigation-page-handler.js"></script>
</MainGridLayout>

<style>
	#navigation-search:focus {
		box-shadow: 0 0 0 3px var(--primary) / 0.1;
	}

	.no-results-panel {
		opacity: 0;
		transform: translateY(8px);
		visibility: hidden;
		pointer-events: none;
		transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0.18s;
	}

	.no-results-panel.is-visible {
		opacity: 1;
		transform: translateY(0);
		visibility: visible;
		pointer-events: auto;
		transition: opacity 0.18s ease, transform 0.18s ease;
	}
</style>
