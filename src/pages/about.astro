---
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import CenterTitle from "../components/CenterTitle.astro";
import Twikoo from "@components/comment/Twikoo.astro";
const aboutPost = await getEntry("spec", "about");

if (!aboutPost) {
	throw new Error("About page content not found");
}

const { Content } = await render(aboutPost);
const title = i18n(I18nKey.about);
const subtitle = I18nKey.about;
// const watermark = I18nKey.about;
---

<MainGridLayout title={title}>
	<!-- 引入右侧边栏布局管理器 -->
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>
	<div
		class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32 mb-4"
	>
		<div
			class="card-base z-10 px-9 py-6 relative w-full"
			id="post-container"
		>
			<!-- 页面标题 -->
			<CenterTitle
				title={title}
				subtitle={subtitle}
				watermark={false}
				bgImage="https://www.loliapi.com/acg/pc?t=about"
			/>
			<!-- 从MD文件读取的内容 -->
			<Markdown class="mt-2">
				<Content />
			</Markdown>
		</div>
	</div>
	<div class="card-base p-6 mb-4">
		<Twikoo path="/friends" />
	</div>
</MainGridLayout>
