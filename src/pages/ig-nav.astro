---
import { FilterTabs } from "@components/atoms/filter-tabs";
import { FilterEmptyState } from "@components/atoms/empty-state";
import { PageHeader } from "@components/features/page-header";
import IgNavCard from "@components/features/ig-nav/IgNavCard.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

import { siteConfig } from "../config";
import { getShuffledIgNavsList, tagPriority } from "../data/ig-nav";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

export const prerender = true;

if (!siteConfig.featurePages.igNav) {
	return Astro.redirect("/404/");
}

const igNavsList = getShuffledIgNavsList();
const allTags = Array.from(new Set(igNavsList.flatMap((item) => item.tags)));
const filterTabs = [
	{ value: "all", label: "全部", count: igNavsList.length },
	...allTags.map((tag) => ({
		value: tag,
		label: tag,
		count: igNavsList.filter((item) => item.tags.includes(tag)).length,
	})),
];
---

<MainGridLayout title="Navigation" description="个人导航页">
	<script is:inline>
		window.isIgNavPage = true;
	</script>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<PageHeader
				title="Navigation"
				subtitle="个人导航页"
				bgImage="https://www.loliapi.com/acg/pc?t=ig-nav"
			/>

			<div class="mb-6 space-y-3">
				<div class="w-full">
					<div class="relative">
						<input
							type="text"
							id="ig-nav-search"
							placeholder="搜索网站名称或描述..."
							class="w-full px-4 py-2 pl-10 rounded-lg bg-[var(--btn-regular-bg)]
									text-black/90 dark:text-white/90
									border border-black/10 dark:border-white/10
									focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50
									transition-all duration-200"
						/>
						<svg
							class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-black/40 dark:text-white/40"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
							></path>
						</svg>
					</div>
				</div>

				<FilterTabs
					tabs={filterTabs}
					dataAttr="tags"
					priorityValues={tagPriority}
				/>
			</div>

			<div id="ig-nav-grid" class="grid grid-cols-1 gap-4 mb-6">
				{
					igNavsList.map((item) => (
						<IgNavCard item={item} visitText="访问" copyText="复制链接" />
					))
				}
			</div>

			<div id="no-results" class="hidden">
				<FilterEmptyState />
			</div>

			<div id="ig-nav-copy-success-text" style="display: none;">
				{i18n(I18nKey.friendsCopySuccess)}
			</div>
		</div>
	</div>

	<script is:inline src="/js/filter-tabs-handler.js"></script>
	<script is:inline src="/js/ig-nav-page-handler.js"></script>
</MainGridLayout>

<style>
	#ig-nav-search:focus {
		box-shadow: 0 0 0 3px var(--primary) / 0.1;
	}
</style>
