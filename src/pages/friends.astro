---
import FriendCard from "@components/features/friends/FriendCard.astro";
import Comment from "@components/comment/index.astro";
import { FilterTabs } from "@components/atoms/filter-tabs";
import { PageHeader } from "@components/features/page-header";
import Markdown from "@components/misc/Markdown.astro";
import { FilterEmptyState } from "@components/atoms/empty-state";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getEntry, render } from "astro:content";

import { siteConfig } from "../config";
import { getShuffledFriendsList, tagPriority } from "../data/friends";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

export const prerender = true;

if (!siteConfig.featurePages.friends) {
	return Astro.redirect("/404/");
}

const friendsPost = await getEntry("spec", "friends");

if (!friendsPost) {
	throw new Error("friends page content not found");
}

const { Content } = await render(friendsPost);
const friendsList = getShuffledFriendsList();
const allTags = Array.from(new Set(friendsList.flatMap((item) => item.tags)));
const filterTabs = [
	{
		value: "all",
		label: i18n(I18nKey.friendsFilterAll),
		count: friendsList.length,
	},
	...allTags.map((tag) => ({
		value: tag,
		label: tag,
		count: friendsList.filter((item) => item.tags.includes(tag)).length,
	})),
];
---

<MainGridLayout
	title={i18n(I18nKey.friends)}
	description={i18n(I18nKey.friends)}
>
	<script is:inline>
		window.isFriendsPage = true;
	</script>
	<script>
		import("../scripts/right-sidebar-layout.js");
		import { loadIconify } from "../utils/icon-loader";

		loadIconify().catch((error) => {
			console.error("Failed to load Iconify:", error);
		});
	</script>

	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<PageHeader
				title={i18n(I18nKey.friends)}
				subtitle={i18n(I18nKey.friendsSubtitle)}
				bgImage="https://www.loliapi.com/acg/pc?t=friend"
			/>

			<!-- 搜索和筛选栏 -->
			<div class="mb-6 space-y-3">
				<!-- 搜索框 -->
				<div class="w-full">
					<div class="relative">
						<input
							type="text"
							id="friend-search"
							placeholder={i18n(I18nKey.friendsSearchPlaceholder)}
							class="w-full px-4 py-2 pl-10 rounded-lg bg-[var(--btn-regular-bg)]
									text-black/90 dark:text-white/90
									border border-black/10 dark:border-white/10
									focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50
									transition-all duration-200"
						/>
						<svg
							class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-black/40 dark:text-white/40"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
							></path>
						</svg>
					</div>
				</div>

				<!-- 标签筛选 -->
				<FilterTabs
					tabs={filterTabs}
					dataAttr="tags"
					priorityValues={tagPriority}
					emptyTarget="none"
				/>
			</div>

			<!-- 友链卡片网格 -->
			<div
				id="friends-grid"
				class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 mb-6"
			>
				{friendsList.map((item) => <FriendCard friend={item} />)}
			</div>

			<!-- 无结果提示 -->
			<div id="no-results" class="no-results-panel">
				<FilterEmptyState />
			</div>

			<!-- 说明文档 -->
			<Markdown class="mt-8 prose dark:prose-invert max-w-none">
				<Content />
			</Markdown>

			<!-- 隐藏元素用于传递 i18n 文本到全局脚本 -->
			<div id="friends-copy-success-text" style="display: none;">
				{i18n(I18nKey.friendsCopySuccess)}
			</div>
		</div>
	</div>

	<!-- 引用全局脚本 -->
	<script is:inline src="/js/filter-tabs-handler.js"></script>
	<script is:inline src="/js/friends-page-handler.js"></script>

	<Comment path="/friends/" />
</MainGridLayout>

<style>
	/* 搜索框焦点效果 */
	#friend-search:focus {
		box-shadow: 0 0 0 3px var(--primary) / 0.1;
	}

	.no-results-panel {
		opacity: 0;
		transform: translateY(8px);
		visibility: hidden;
		pointer-events: none;
		transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0.18s;
	}

	.no-results-panel.is-visible {
		opacity: 1;
		transform: translateY(0);
		visibility: visible;
		pointer-events: auto;
		transition: opacity 0.18s ease, transform 0.18s ease;
	}

</style>
